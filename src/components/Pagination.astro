---
// Shared Previous / "Page X of Y" / Next control. Callers supply hrefFor(page)
// so each list keeps its own query-string shape. Styling is global (.pagination).
interface Props {
  page: number;
  totalPages: number;
  hrefFor: (p: number) => string;
  nextLabel?: string;
}
const { page, totalPages, hrefFor, nextLabel = 'Next' } = Astro.props;
---

{totalPages > 1 && (
  <div class="pagination">
    {page > 1
      ? <a href={hrefFor(page - 1)}>&#9664; Previous</a>
      : <span class="page-disabled">&#9664; Previous</span>}
    <span class="page-of">Page {page} of {totalPages}</span>
    {page < totalPages
      ? <a href={hrefFor(page + 1)}>{nextLabel} &#9654;</a>
      : <span class="page-disabled">{nextLabel} &#9654;</span>}
  </div>
)}
