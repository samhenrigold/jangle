---
import '../styles/global.css';
import TopNavigation from './TopNavigation.astro';

const {
  title = 'Legacy Store',
  activeTab = 'featured',
  description = 'Legacy Store — install archived versions of classic iPhone and iPad apps directly on old iOS devices.',
  searchQuery = '',
  mobileSearch = false,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <TopNavigation activeTab={activeTab} searchQuery={searchQuery} mobileSearch={mobileSearch} />

    <main class="site-main">
      <slot />
    </main>
  </body>
</html>
