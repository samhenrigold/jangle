---
import '../styles/global.css';
import TopNavigation from './TopNavigation.astro';

const {
  title = 'Legacy Store',
  activeTab = 'featured',
  description = 'Legacy Store — install archived versions of classic iPhone and iPad apps directly on old iOS devices.',
  searchQuery = '',
  mobileSearch = false,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <TopNavigation activeTab={activeTab} searchQuery={searchQuery} mobileSearch={mobileSearch} />

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <span class="footer-brand">Legacy Store</span>
        <span class="footer-sep">·</span>
        <a href="/colophon">Colophon</a>
        <span class="footer-sep">·</span>
        <a href="https://github.com/samhenrigold/jangle" rel="noopener">Source</a>
        <span class="footer-sep">·</span>
        <a href="/stats">Stats</a>
      </div>
      <p class="footer-note">A metadata-only preservation archive. App binaries are hosted by the Internet Archive, not here.</p>
    </footer>

    <style>
      .site-footer {
        border-top: 1px solid #e1e1e1;
        margin-top: 24px;
        padding: 16px 8px 28px 8px;
        text-align: center;
        color: #8e8e93;
        font-size: 12px;
        line-height: 18px;
      }

      .site-footer-inner a {
        color: #385487;
        font-weight: bold;
      }

      .footer-brand {
        font-weight: bold;
        color: #666;
      }

      .footer-sep {
        margin: 0 6px;
        color: #c7c7cc;
      }

      .footer-note {
        margin: 6px auto 0 auto;
        max-width: 460px;
      }
    </style>
  </body>
</html>
