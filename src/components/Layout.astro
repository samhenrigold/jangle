---
import '../styles/global.css';
import { SITE_ORIGIN } from '../lib/http';

const {
  title = 'Legacy Store',
  activeTab = 'featured',
  description = 'Legacy Store — install archived versions of classic iPhone and iPad apps directly on old iOS devices.',
  searchQuery = '',
  // Set on pages reachable under several URLs (an app has app_store_id,
  // internal-id, and bundle-id aliases plus filter params) so search engines
  // consolidate them. Omit everywhere else.
  canonicalPath = '',
  // Extra class on <body> for page-specific chrome (e.g. 'charts-landing').
  bodyClass = '',
  // Open Graph card for link sharing: { title?, description?, path, image?,
  // type? }. Omit on pages that don't need a rich unfurl.
  og = null,
} = Astro.props;

// The productheader row carries the real site navigation — the slot the
// original page used for its apple.com/itunes links.
const NAV = [
  { key: 'featured', label: 'Featured', href: '/' },
  { key: 'charts', label: 'Charts', href: '/charts' },
  { key: 'categories', label: 'Categories', href: '/categories' },
  { key: 'collections', label: 'Collections', href: '/collections' },
  { key: 'colophon', label: 'Colophon', href: '/colophon' },
  { key: 'search', label: 'Search', href: '/search' },
];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {canonicalPath && <link rel="canonical" href={SITE_ORIGIN + canonicalPath} />}
    {og && (
      <>
        <meta property="og:site_name" content="Legacy Store" />
        <meta property="og:type" content={og.type || 'website'} />
        <meta property="og:title" content={og.title || title} />
        <meta property="og:description" content={og.description || description} />
        {og.path && <meta property="og:url" content={SITE_ORIGIN + og.path} />}
        {og.image && <meta property="og:image" content={og.image} />}
        <meta name="twitter:card" content="summary" />
      </>
    )}
    <title>{title}</title>
    <!-- Tag <html> with the device type before paint, so device-specific CSS
         (e.g. Install vs Download on app pages) applies without a flash. Pages
         render identically for every device and edge-cache; this class is the
         only per-device branch, done on the client. Old-WebKit-safe. -->
    <script is:inline>
      (function () {
        try {
          var ua = navigator.userAgent, d = document.documentElement;
          if (/iPhone|iPad|iPod/.test(ua)) {
            d.className += (d.className ? ' ' : '') + 'is-ios';
            var m = ua.match(/OS (\d+)_/);
            if (m) d.setAttribute('data-ios', m[1]);
          } else {
            d.className += (d.className ? ' ' : '') + 'is-desktop';
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class={bodyClass ? `software ${bodyClass}` : 'software'}>
    <div id="productheader">
      <h2><a class="wordmark" href="/"><img src="/wsf/images/legacystore.png" srcset="/wsf/images/legacystore@2x.png 2x" width="171" height="32" alt="Legacy Store" /></a></h2>
      <form class="ph-search" action="/search" method="get">
        <span class="search-wrapper">
          <span class="left"></span>
          <input type="search" name="q" value={searchQuery} placeholder="Search" aria-label="Search Legacy Store" />
          <span class="right"></span>
        </span>
      </form>
      <ul>
        {NAV.map((n) => (
          <li><a href={n.href} class={activeTab === n.key ? 'active' : undefined}>{n.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Phone-only search strip (the sprite nav above is hidden < 768px) -->
    <form id="phonesearch" action="/search" method="get">
      <span class="search-wrapper">
        <span class="left"></span>
        <input type="search" name="q" value={searchQuery} placeholder="Search" aria-label="Search Legacy Store" />
        <span class="right"></span>
      </span>
    </form>

    <div id="main">
      <div id="content">
        <div class="cap top"></div>
        <div class="padder">
          <slot />
        </div>
        <div class="cap bottom"></div>
      </div>
    </div>

    <!-- Press "/" anywhere to jump to the search box (unless you're already
         typing in a field). A keyboard nicety for desktop; touch devices never
         reach it. Old-WebKit-safe (var, keyCode fallback, no ES6). -->
    <script is:inline>
      (function () {
        try {
          document.addEventListener('keydown', function (e) {
            var isSlash = e.key === '/' || (!e.key && e.keyCode === 191 && !e.shiftKey);
            if (!isSlash || e.metaKey || e.ctrlKey || e.altKey) return;
            var t = e.target || {};
            var tag = (t.tagName || '').toLowerCase();
            if (tag === 'input' || tag === 'textarea' || tag === 'select' || t.isContentEditable) return;
            var inputs = document.querySelectorAll('input[type="search"][name="q"]');
            for (var i = 0; i < inputs.length; i++) {
              // Focus the one that's actually visible at this width (desktop
              // header vs the phone strip); offsetParent is null when hidden.
              if (inputs[i].offsetParent !== null) {
                e.preventDefault();
                inputs[i].focus();
                try { inputs[i].select(); } catch (err) {}
                return;
              }
            }
          });
        } catch (e) {}
      })();
    </script>

    <div id="globalfooter">
      <p class="gf-buy">A metadata-only preservation archive. App binaries are hosted by the <a href="https://archive.org/" rel="noopener">Internet Archive</a>, not here.</p>
      <ul class="gf-links piped">
        <li><a href="/colophon" class="first">Colophon</a></li>
        <li><a href="/contribute">Contribute</a></li>
        <li><a href="/stats">Stats</a></li>
        <li><a href="https://github.com/samhenrigold/jangle" rel="noopener">Source</a></li>
      </ul>
    </div>
  </body>
</html>
