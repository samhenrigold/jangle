---
import '../styles/global.css';
import { SITE_ORIGIN } from '../lib/http';

const {
  title = 'Legacy Store',
  activeTab = 'featured',
  description = 'Legacy Store — install archived versions of classic iPhone and iPad apps directly on old iOS devices.',
  searchQuery = '',
  // Breadcrumb label for the footer trail; defaults to the active nav item,
  // else the page title's first segment.
  crumb = '',
  // Set on pages reachable under several URLs (an app has app_store_id,
  // internal-id, and bundle-id aliases plus filter params) so search engines
  // consolidate them. Omit everywhere else.
  canonicalPath = '',
  // Extra class on <body> for page-specific chrome (e.g. 'charts-landing').
  bodyClass = '',
} = Astro.props;

// The productheader row carries the real site navigation — the slot the
// original page used for its apple.com/itunes links.
const NAV = [
  { key: 'featured', label: 'Featured', href: '/' },
  { key: 'charts', label: 'Charts', href: '/charts' },
  { key: 'categories', label: 'Categories', href: '/categories' },
  { key: 'most-archived', label: 'Most Archived', href: '/most-archived' },
  { key: 'search', label: 'Search', href: '/search' },
];
const crumbLabel =
  crumb ||
  NAV.find((n) => n.key === activeTab)?.label ||
  (title.split(' — ')[0] || 'Legacy Store');
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {canonicalPath && <link rel="canonical" href={SITE_ORIGIN + canonicalPath} />}
    <title>{title}</title>
    <!-- Tag <html> with the device type before paint, so device-specific CSS
         (e.g. Install vs Download on app pages) applies without a flash. Pages
         render identically for every device and edge-cache; this class is the
         only per-device branch, done on the client. Old-WebKit-safe. -->
    <script is:inline>
      (function () {
        try {
          var ua = navigator.userAgent, d = document.documentElement;
          if (/iPhone|iPad|iPod/.test(ua)) {
            d.className += (d.className ? ' ' : '') + 'is-ios';
            var m = ua.match(/OS (\d+)_/);
            if (m) d.setAttribute('data-ios', m[1]);
          } else {
            d.className += (d.className ? ' ' : '') + 'is-desktop';
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class={bodyClass ? `software ${bodyClass}` : 'software'}>
    <div id="productheader">
      <h2><a class="wordmark" href="/"><img src="/wsf/images/legacystore.png" srcset="/wsf/images/legacystore@2x.png 2x" width="179" height="32" alt="Legacy Store" /></a></h2>
      <form class="ph-search" action="/search" method="get">
        <span class="search-wrapper">
          <span class="left"></span>
          <input type="search" name="q" value={searchQuery} placeholder="Search" aria-label="Search Legacy Store" />
          <span class="right"></span>
        </span>
      </form>
      <ul>
        {NAV.map((n) => (
          <li><a href={n.href} class={activeTab === n.key ? 'active' : undefined}>{n.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Phone-only search strip (the sprite nav above is hidden < 768px) -->
    <form id="phonesearch" action="/search" method="get">
      <span class="search-wrapper">
        <span class="left"></span>
        <input type="search" name="q" value={searchQuery} placeholder="Search" aria-label="Search Legacy Store" />
        <span class="right"></span>
      </span>
    </form>

    <div id="main">
      <div id="content">
        <div class="cap top"></div>
        <div class="padder">
          <slot />
        </div>
        <div class="cap bottom"></div>
      </div>
    </div>

    <div id="globalfooter">
      <div id="breadory">
        <ol id="breadcrumbs">
          <li class="home"><a href="/">Home</a></li>
          <li>{crumbLabel}</li>
        </ol>
        <div id="directorynav" class="itunes">
          <div id="dn-cola" class="column first">
            <h3>Browse</h3>
            <ul>
              <li><a href="/">Featured</a></li>
              <li><a href="/charts">Charts</a></li>
              <li><a href="/categories">Categories</a></li>
              <li><a href="/most-archived">Most Archived</a></li>
              <li><a href="/search">Search</a></li>
            </ul>
          </div>
          <div id="dn-colb" class="column">
            <h3>About</h3>
            <ul>
              <li><a href="/colophon">Colophon</a></li>
              <li><a href="/stats">Archive Stats</a></li>
            </ul>
          </div>
          <div id="dn-colc" class="column">
            <h3>Elsewhere</h3>
            <ul>
              <li><a href="https://github.com/samhenrigold/jangle" rel="noopener">Source on GitHub</a></li>
              <li><a href="https://archive.org/" rel="noopener">Internet Archive</a></li>
            </ul>
          </div>
          <div class="capbottom"></div>
        </div>
      </div>
      <p class="gf-buy">A metadata-only preservation archive. App binaries are hosted by the <a href="https://archive.org/" rel="noopener">Internet Archive</a>, not here.</p>
      <ul class="gf-links piped">
        <li><a href="/colophon" class="first">Colophon</a></li>
        <li><a href="/stats">Stats</a></li>
        <li><a href="https://github.com/samhenrigold/jangle" class="contact_us" rel="noopener">Source</a></li>
        <li><a href="/" class="choose" title="United States"><img src="/wsf/nav/worldwide_us.png" alt="United States" width="22" height="22" /></a></li>
      </ul>
      <div class="gf-sosumi">
        <p>Not affiliated with Apple Inc. Design recreated from the 2010 iTunes Preview website for preservation.</p>
        <ul class="piped">
          <li><a href="/colophon" class="first">About this design</a></li>
        </ul>
      </div>
    </div>
  </body>
</html>
