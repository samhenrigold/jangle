---
const { title = 'Jangle' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body style="font-family:-apple-system, system-ui, sans-serif;margin:0;">
    <div style="padding:12px 16px;border-bottom:1px solid #ddd;">
      <a href="/" style="color:inherit;text-decoration:none;">Jangle</a>
    </div>
    <main style="padding:16px;">
      <slot />
    </main>
  </body>
</html>


