---
import SegmentedControl from './SegmentedControl.astro';
import SearchButton from './SearchButton.astro';
import SearchField from './SearchField.astro';

// mobileSearch swaps the phone layout from [tabs + search button] to
// [search field over tabs] (used on /search, so phones keep the tab bar
// instead of dead-ending on a lone search field).
const { activeTab = 'featured', searchQuery = '', mobileSearch = false } = Astro.props;
---

<nav class={mobileSearch ? 'top-nav has-mobile-search' : 'top-nav'}>
  <div class="nav-background"></div>
  {mobileSearch && (
    <div class="mobile-rows">
      <SearchField value={searchQuery} variant="mobile" />
      <div class="mobile-tabs">
        <SegmentedControl activeTab={activeTab} variant="static" />
      </div>
    </div>
  )}
  <div class="main-row">
    <SegmentedControl activeTab={activeTab} />
    {!mobileSearch && <SearchButton activeTab={activeTab} />}
    <div class="spacer"></div>
    <SearchField value={searchQuery} />
  </div>
</nav>

<style>
  .top-nav {
    position: relative;
    width: 100%;
  }

  .nav-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('/UINavigationBar/UINavigationBarDefaultBackground.png');
    background-repeat: repeat-x;
    background-size: 1px 100%;
  }

  .main-row {
    position: relative;
    height: 60px;
  }

  /* Mobile search rows (only rendered with mobileSearch) */
  .mobile-rows {
    display: none;
  }

  .has-mobile-search .mobile-rows {
    display: block;
    position: relative;
    padding: 9px 8px;
  }

  .has-mobile-search .main-row {
    display: none;
  }

  .mobile-tabs {
    margin-top: 8px;
  }

  /* Spacer for iPad layout - hidden by default */
  .spacer {
    display: none;
  }

  /* iPad and larger screens */
  @media screen and (min-width: 768px) {
    .main-row,
    .has-mobile-search .main-row {
      display: -webkit-box;
      -webkit-box-orient: horizontal;
      -webkit-box-align: center;
      -webkit-box-pack: justify;
      padding: 0 8px;
    }

    .has-mobile-search .mobile-rows {
      display: none;
    }

    .spacer {
      display: block;
      width: 33.333%;
      height: 30pt;
      -webkit-box-ordinal-group: 1;
    }
  }

  @media only screen and (-webkit-min-device-pixel-ratio: 2) {
    .nav-background {
      background: url('/UINavigationBar/UINavigationBarDefaultBackground@2x.png');
      background-size: 1px 100%;
    }
  }
</style>
