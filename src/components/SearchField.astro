---
interface Props {
  value?: string;
  // 'ipad' (default): hidden on phones, becomes the right column of the nav
  // row on iPad and larger. 'mobile': a full-width row (the /search page's
  // phone layout, rendered above the tab bar).
  variant?: 'ipad' | 'mobile';
}

const { value = '', variant = 'ipad' } = Astro.props;
---

<form class={`search-field ${variant === 'mobile' ? 'sf-mobile' : 'sf-ipad'}`} action="/search" method="get" onsubmit="this.q.value = this.q.value.trim()">
  <div class="search-field-icon"></div>
  <input type="search" class="search-input" name="q" placeholder="Search" value={value} autocapitalize="off" autocorrect="off" />
</form>

<style>
  /* Shared chrome for both variants: UIKit slice-image shell (left cap as the
     element background, middle/right caps as pseudo-elements), the magnifier
     icon, and a borderless input over it all. */
  .search-field {
    height: 26pt;
    position: relative;
    margin: 0;
    background-image: url('/UISearchField/UISearchFieldLeftSharp.png');
    background-repeat: no-repeat;
    background-size: 13pt 26pt;
    background-position: left center;
    box-sizing: border-box;
  }

  .search-field::before {
    content: '';
    position: absolute;
    top: 0;
    left: 13pt;
    right: 13pt;
    height: 26pt;
    background-image: url('/UISearchField/UISearchFieldMiddleSharp.png');
    background-repeat: repeat-x;
    background-size: 1pt 26pt;
  }

  .search-field::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 13pt;
    height: 26pt;
    background-image: url('/UISearchField/UISearchFieldRightSharp.png');
    background-repeat: no-repeat;
    background-size: 13pt 26pt;
    background-position: right center;
  }

  .search-field-icon {
    position: absolute;
    top: 50%;
    left: 8pt;
    width: 12pt;
    height: 12pt;
    margin-top: -6pt;
    background-image: url('/UISearchField/UISearchFieldIcon.png');
    background-repeat: no-repeat;
    background-size: 12pt 12pt;
    z-index: 2;
    pointer-events: none;
  }

  .search-input {
    position: absolute;
    top: 0;
    left: 25pt;
    right: 13pt;
    height: 26pt;
    border: none;
    background: transparent;
    font-family: Helvetica, "Helvetica Neue", system-ui, sans-serif;
    color: #000;
    padding: 0 4pt;
    z-index: 1;
    box-sizing: border-box;
    line-height: 26pt;
    margin: 0;
    /* Old iOS draws its own search-field bezel over type=search inputs
       unless appearance is reset — ours comes from the slice images. */
    -webkit-appearance: none;
    border-radius: 0;
  }

  .search-input:focus {
    outline: none;
  }

  /* Phone-row variant: full width; its container decides when it shows. */
  .sf-mobile {
    display: block;
    width: 100%;
  }

  /* Nav-column variant: hidden on phones (they get the SearchButton instead). */
  .sf-ipad {
    display: none;
  }

  /* iPad and larger screens */
  @media screen and (min-width: 768px) {
    .sf-ipad {
      display: block;
      width: 33.333%;
      -webkit-box-ordinal-group: 3;
    }
  }

  @media only screen and (-webkit-min-device-pixel-ratio: 2) {
    .search-field {
      background-image: url('/UISearchField/UISearchFieldLeftSharp@2x.png');
      background-size: 13pt 26pt;
    }

    .search-field::before {
      background-image: url('/UISearchField/UISearchFieldMiddleSharp@2x.png');
      background-size: 1pt 26pt;
    }

    .search-field::after {
      background-image: url('/UISearchField/UISearchFieldRightSharp@2x.png');
      background-size: 13pt 26pt;
    }

    .search-field-icon {
      background-image: url('/UISearchField/UISearchFieldIcon@2x.png');
      background-size: 12pt 12pt;
    }
  }
</style>
