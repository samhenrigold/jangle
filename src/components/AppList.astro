---
import { appIconSrc } from '../lib/icons';
import { appTitleOf } from '../lib/apps';

// startRank: when set, rows are numbered from it (charts / category "top" lists).
// peakLines: optional map of app_store_id → "Peaked at #1 Top Paid · Dec 2010"
// badge text sourced from the archived charts (plan 010).
// iconShas: optional map of internal app id → oldest-icon sha256 (period-
// authentic icon extracted from the app's earliest binary); when present it
// wins over the modern iTunes CDN icon_url.
const { list = [], startRank, peakLines, iconShas } = Astro.props;
---
<ul class="applist">
  {list.map((a: any, i: number) => {
    const oldSha = iconShas && a.id != null ? iconShas.get(Number(a.id)) : null;
    const icon = appIconSrc(oldSha, a.icon_url);
    const count = a.version_count == null ? null : Number(a.version_count);
    const peak = peakLines && a.app_store_id ? peakLines.get(Number(a.app_store_id)) : null;
    return (
    <li class="app" data-app-store-id={a.app_store_id || undefined} data-bundle-id={a.bundle_id || undefined}>
      <a class="app-link" href={`/app/${a.app_store_id ? a.app_store_id : a.id}`}>
        {typeof startRank === 'number' && <span class="rank">{startRank + i}</span>}
        {/* The corner mask only goes over a real square icon; a missing icon
            shows the already-rounded placeholder, so no mask (its opaque
            corners would mismatch the background). */}
        <span class="icon">{icon ? <><img src={icon} alt="" width="60" height="60" loading="lazy" decoding="async" /><span class="icon-mask"></span></> : null}</span>
        <span class="chevron">&#8250;</span>
        {count != null && count > 0 && (
          <span class="count">{count}<span class="count-label">{count === 1 ? 'version' : 'versions'}</span></span>
        )}
        <span class="info">
          <span class="name">{appTitleOf(a)}</span>
          {a.developer_artist_name && <span class="meta">{a.developer_artist_name}</span>}
          {a.bundle_id && <span class="meta meta-bundle">{a.bundle_id}</span>}
          {peak && <span class="peak">{peak}</span>}
        </span>
      </a>
    </li>
    );
  })}
  {list.length === 0 && <li class="applist-empty">Nothing here yet.</li>}
</ul>
