---
import { iconSrc } from '../lib/icons';

// startRank: when set, rows are numbered from it (charts / category "top" lists).
const { list = [], startRank } = Astro.props;

// app_store_name is the iTunes listing name ("Angry Birds HD Free") and
// disambiguates the many apps whose bundle display_name is identical.
const titleOf = (a: any) => a.app_store_name || a.display_name || a.bundle_id;
---
<ul class="applist">
  {list.map((a: any, i: number) => {
    const icon = iconSrc(a.icon_url);
    const count = a.version_count == null ? null : Number(a.version_count);
    return (
    <li class="app">
      <a class="app-link" href={`/app/${a.app_store_id ? a.app_store_id : a.id}`}>
        {typeof startRank === 'number' && <span class="rank">{startRank + i}</span>}
        <span class="icon">{icon && <img src={icon} alt="" width="57" height="57" />}</span>
        <span class="chevron">&#8250;</span>
        {count != null && count > 0 && (
          <span class="count">{count}<span class="count-label">{count === 1 ? 'version' : 'versions'}</span></span>
        )}
        <span class="info">
          <span class="name">{titleOf(a)}</span>
          <span class="meta">{[a.developer_artist_name, a.bundle_id].filter(Boolean).join(' · ')}</span>
        </span>
      </a>
    </li>
    );
  })}
  {list.length === 0 && <li class="applist-empty">Nothing here yet.</li>}
</ul>
