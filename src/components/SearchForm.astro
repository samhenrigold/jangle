---
const { q = '', genreId = '', sort = 'versions', genres = [] } = Astro.props;

// Group Game subgenres after the parent Games genre
const sortedGenres = genres.sort((a: any, b: any) => {
  // If a is the Games genre (id 6014), it should come first
  if (a.id === 6014) return -1;
  if (b.id === 6014) return 1;
  
  // If a is a Game subgenre (starts with "70"), it should come after Games but before other genres
  if (a.genre_id && String(a.genre_id).startsWith('70')) {
    // If b is also a Game subgenre, sort them alphabetically
    if (b.genre_id && String(b.genre_id).startsWith('70')) {
      return a.genre_name.localeCompare(b.genre_name);
    }
    // If b is not a Game subgenre, a should come first (after Games)
    return -1;
  }
  
  // If b is a Game subgenre but a is not, b should come after Games
  if (b.genre_id && String(b.genre_id).startsWith('70')) {
    return 1;
  }
  
  // For all other genres, maintain alphabetical order
  return a.genre_name.localeCompare(b.genre_name);
});
---
<form class="search" method="get" action="/search">
  <input type="text" name="q" value={q} placeholder="Search apps, bundle id, developer" />
  <select name="genre">
    <option value="">All genres</option>
    {sortedGenres.map((g: any) => (
      <option value={g.id} selected={String(g.id) === String(genreId)}>{g.genre_name} ({g.app_count})</option>
    ))}
  </select>
  <select name="sort">
    <option value="versions" selected={sort==='versions'}>Most versions</option>
    <option value="first_date" selected={sort==='first_date'}>Oldest first release</option>
    <option value="name" selected={sort==='name'}>Name A-Z</option>
  </select>
  <button type="submit">Search</button>
</form>