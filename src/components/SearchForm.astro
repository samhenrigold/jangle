---
// `genres` arrives already sorted by the page (see src/lib/genres.ts) — do not
// re-sort here (that mutated the shared cached array and double-sorted).
// The query text lives in the nav search field; this form only refines an
// existing search, carrying q through a hidden input.
import { formatNumber } from '../lib/format';
const { q = '', genreId = '', sort = 'versions', genres = [] } = Astro.props;
---
<form class="filters" method="get" action="/search">
  <input type="hidden" name="q" value={q} />
  <select name="genre" aria-label="Genre">
    <option value="">All genres</option>
    {genres.map((g: any) => (
      <option value={g.id} selected={String(g.id) === String(genreId)}>{g.genre_name} ({formatNumber(g.app_count)})</option>
    ))}
  </select>
  <select name="sort" aria-label="Sort by">
    <option value="versions" selected={sort==='versions'}>Most versions</option>
    <option value="first_date" selected={sort==='first_date'}>Oldest first release</option>
    <option value="name" selected={sort==='name'}>Name A&ndash;Z</option>
  </select>
  <button type="submit">Apply</button>
</form>
