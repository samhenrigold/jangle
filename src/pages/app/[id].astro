  <script is:inline>
    (function () {
      if (!document.querySelectorAll || !document.getElementsByTagName) return;

      function hasClass(el, c) {
        return (' ' + el.className + ' ').indexOf(' ' + c + ' ') > -1;
      }
      function addClass(el, c) {
