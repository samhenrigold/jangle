        for (i = 0; i < everythingToggles.length; i++) {
          (function (link) {
            link.onclick = function (e) {
              if (!versionsRoot) return true;
              if (hasClass(versionsRoot, 'show-everything')) {
                removeClass(versionsRoot, 'show-everything');
                setAllExpanded(false);
                link.innerHTML = link.getAttribute('data-expand');
              } else {
                addClass(versionsRoot, 'show-everything');
                setAllExpanded(true);
                link.innerHTML = link.getAttribute('data-collapse');
              }
              if (e && e.preventDefault) e.preventDefault();
              return false;
            };
          })(everythingToggles[i]);
        }

        // 1b) Per-row expand — clicking the TOP section (.v-lockup) of a version
        //     row that has extra copies reveals that row's copies inline.
        //     Delegated off the container. Clicks on Install/Download links pass
        //     through; clicks on the already-revealed copies (.v-copies) do NOT
