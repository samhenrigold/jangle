      display: block;
      margin-top: 5px;
      color: #666;
      font-size: 12px;
      line-height: 15px;
    }

    /* Size on one line, Encrypted badge on its own line underneath. */
    .file-stat .file-stat-size {
      display: block;
    }

    .file-stat .chip {
      margin-top: 3px;
    }

    /* Disabled action (no available file): looks like a button, does nothing. */
    .navbtn-disabled {
      opacity: 0.4;
    }

    /* Universal ("fat binary") apps: Apple's + badge, rendered as a pseudo-
       element (no markup) pinned to the button's top-left corner. Nudged -1px
       over the border; the button's overflow:hidden clips it to the corner
       radius. Retina 28px source shown at 14px. */
    .nav-universal::before {
      content: '';
      position: absolute;
      top: -1px;
      left: -1px;
      width: 14px;
      height: 14px;
      background: url('/fat-binary-badge.png') 0 0 no-repeat;
      background-size: 14px 14px;
    }

    .file-name {
      display: block;
      overflow: hidden;
      color: #8e8e93;
      font-size: 12px;
      line-height: 15px;
      padding-top: 2px;
      word-break: break-all;
    }

    /* Encrypted badge sits on its own line below the file name in a copy row. */
    .file-chip {
      display: block;
      margin-top: 3px;
    }

    .copies-link {
      color: #385487;
      font-weight: bold;
    }

    .v-nofile {
      color: #8e8e93;
    }

    /* Extra breathing room between the versions list and the chart. */
    .size-header {
      margin-top: 24px;
    }

    .size-chart {
      padding: 10px;
    }

    /* --- Progressive-enhancement hooks (each defaults to the no-JS state) --- */

    /* "Show everything" reveals extra copies AND versions hidden by default
       (unavailable, or encrypted-only). Toggled by the JS class, or the ?all=1
       server class on the no-JS path. */
    .v-extra,
    .v-hidden-default {
      display: none;
    }

    .show-everything .v-extra {
      display: flex;
    }

    .show-everything .v-hidden-default {
      display: block;
    }

    /* Versions too new for the visitor's device, hidden by the client-side
       "Runs on" filter. */
    .v-hidden-os {
      display: none;
    }

    /* Install vs Download visibility lives in the is:global block below —
       the .is-ios/.is-desktop class is on <html>, outside these scoped styles. */

    /* Wayback history sections (iOS grouped-table style, same as .versions) */
    .history-card {
      border: 1px solid #e1e1e1;
      border-radius: 8px;
      background: #fff;
      overflow: hidden;
    }

