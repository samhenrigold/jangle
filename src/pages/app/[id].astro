        }

        // 4) Screenshot-set picker — switch which archived listing capture's
        //    strip is visible. Enabled here so no-JS users get an inert (not
        //    misleading) control showing the one set they can actually see.
        var shotsPicker = document.querySelector('select.js-shots-picker');
        if (shotsPicker) {
          var shotSets = document.querySelectorAll('.shot-set');
          shotsPicker.disabled = false;
          shotsPicker.onchange = function () {
            var sel = shotsPicker.value;
            for (var s = 0; s < shotSets.length; s++) {
              if (shotSets[s].getAttribute('data-shot-set') === sel) addClass(shotSets[s], 'is-active');
              else removeClass(shotSets[s], 'is-active');
            }
          };
        }
      });
    })();
  </script>
</Layout>
