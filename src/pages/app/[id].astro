---
import { getSupabaseClient } from '../../lib/supabase';
import Layout from '../../components/Layout.astro';
import { cacheGet, cacheSet } from '../../lib/cache';

const { id } = Astro.params;
const supabase = getSupabaseClient(Astro.locals?.runtime?.env as any);

// App details
const appCacheKey = `app:${id}`;
let appData = cacheGet<any>(appCacheKey);
if (!appData) {
  const { data } = await supabase
    .from('apps')
    .select('*, developers!apps_developer_id_fkey(artist_name), genres!apps_genre_id_fkey(genre_name)')
    .eq('id', id)
    .single();
  appData = data;
  if (appData) cacheSet(appCacheKey, appData, 10 * 60 * 1000);
}

if (!appData) {
  return Astro.redirect('/');
}

// Versions with IPA links (assuming you have a table mapping)
const versionsCacheKey = `versions:${id}`;
let versions = cacheGet<any[]>(versionsCacheKey);
if (!versions) {
  const { data } = await supabase
    .from('app_versions')
    .select('id, version_string, build_number, minimum_os_version, release_date')
    .eq('app_id', id)
    .order('release_date', { ascending: false })
    .limit(200);
  versions = data || [];
  cacheSet(versionsCacheKey, versions, 5 * 60 * 1000);
}

// Fetch IPA files for these versions
const versionIds = (versions || []).map((v: any) => v.id);
let ipaFiles: any[] = [];
if (versionIds.length) {
  const ipaCacheKey = `ipa_files:${versionIds.join(',')}`;
  ipaFiles = cacheGet<any[]>(ipaCacheKey) || [];
  if (ipaFiles.length === 0) {
    const { data } = await supabase
      .from('ipa_files')
      .select('id, app_version_id, filename, has_itunes_metadata, has_itunes_artwork')
      .in('app_version_id', versionIds);
    ipaFiles = data || [];
    cacheSet(ipaCacheKey, ipaFiles, 5 * 60 * 1000);
  }
}

const filesByVersionId = new Map<number, any[]>();
for (const f of ipaFiles) {
  const arr = filesByVersionId.get(f.app_version_id) || [];
  arr.push(f);
  filesByVersionId.set(f.app_version_id, arr);
}
---

<Layout title={`${appData.display_name || appData.bundle_id} — Jangle`}>
  <a href="/">← Back</a>
  <div style="max-width:900px;margin:10px auto 0 auto;">
    <h1>{appData.display_name || appData.bundle_id}</h1>
    <div class="meta" style="color:#666;font-size:13px;">{appData.developers?.artist_name} · {appData.bundle_id}</div>
    <p>{appData.copyright}</p>

    <h2>Versions</h2>
    {(versions || []).map((v: any) => (
      <div class="version" style="border-bottom:1px solid #eee;padding:10px 0;">
        <div><strong>{v.version_string}</strong> ({v.build_number})</div>
        <div class="meta" style="color:#666;font-size:13px;">iOS {v.minimum_os_version || '—'} · {v.release_date ? new Date(v.release_date).toISOString().slice(0,10) : '—'}</div>
        <div>
          {(filesByVersionId.get(v.id) || []).map((f: any) => {
            const url = `/api/manifest?ipa_id=${f.id}`;
            return (
              <a class="install" style="display:inline-block;margin-right:8px;" href={`itms-services://?action=download-manifest&url=${encodeURIComponent(url)}`}>Install</a>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</Layout>


