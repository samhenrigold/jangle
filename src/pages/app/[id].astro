      color: #385487;
      font-size: 13px;
      font-weight: bold;
    }

    .tm-more {
      color: #385487;
      font-weight: bold;
    }

    /* Chart-trajectory sparkline: plain divs so it renders on iOS 3+. Bars
       sit on a shared baseline; taller = higher chart position. */
    .spark {
      margin-top: 6px;
      height: 30px;
      line-height: 30px;
      white-space: nowrap;
      overflow: hidden;
    }

    .spark-bar {
