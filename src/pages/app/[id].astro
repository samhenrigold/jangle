            <div class="section-header">
              <h2 class="section-title">More from {developerName}</h2>
              {appData.developer_id && <span class="section-detail"><a class="tm-more" href={`/developer/${appData.developer_id}`}>All apps ›</a></span>}
            </div>
            <AppList list={moreFromDev} iconShas={moreFromIcons} />
          </>
        )}
