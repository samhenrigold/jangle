      border-bottom: none;
    }

    /* Lockup: icon + stacked facts on the left, action button centered opposite.
       Flexbox (autoprefixed to the 2009 -webkit-box for iOS 4-6) centers the
       button against the whole stack. */
    .v-lockup {
      display: flex;
      align-items: center;
    }

    /* Period-accurate icon for this version, from its build-time bundle icon.
       Masked (rounded + border + shadow) via the App Store overlay. */
    .v-icon {
      position: relative;
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      margin-right: 10px;
      background: #f3f3f3;
      border-radius: 9px;
    }

    .v-icon img {
      display: block;
      width: 44px;
      height: 44px;
      border-radius: 9px;
    }

    .v-body {
      flex: 1;
      min-width: 0;
    }

