                    {(() => {
                      const when = r.reviewed_at
                        ? formatDate(r.reviewed_at)
                        : (formatApproxMonthYear(r.first_seen_ts) ? `~${formatApproxMonthYear(r.first_seen_ts)}` : '');
                      return [r.author ? `by ${r.author}` : '', when, r.app_version ? `v${r.app_version}` : '', r.vote_count > 0 ? `${r.vote_sum} of ${r.vote_count} found helpful` : ''].filter(Boolean).join(' · ');
                    })()}
                  </div>
                  {r.body && <p class="review-body">{r.body}</p>}
