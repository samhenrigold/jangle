---
import { supabaseFor } from '../../lib/supabase';
import Layout from '../../components/Layout.astro';
import DbError from '../../components/DbError.astro';
import { cacheGet, cacheSet } from '../../lib/cache';
import { sortVersions, coerceDir } from '../../lib/sorting';
import { generateIpaDownloadUrl } from '../../lib/urls';
import { iconSrc, appIconSrc } from '../../lib/icons';
import { formatDate, formatFileSize, formatNumber } from '../../lib/format';
import { dedupeFilesByHash, fileLabel, sortGroupsByPreference } from '../../lib/files';
import { setCacheHeaders, setDegraded } from '../../lib/http';
import { resolveApp, appTitleOf } from '../../lib/apps';
import {
  getChartTypes, getGenreNames, getAppChartHistory, getAppRatingHistory, getAppReviews,
  deviceOf, starString, sampleEvenly, formatMonthYear, formatPrice, formatApproxMonthYear,
} from '../../lib/timemachine';
import { pickOldestIcon, getOldestIcons } from '../../lib/appicons';
import SectionHeader from '../../components/SectionHeader.astro';
import { osRequirementLabel, osShortLabel, retinaLabel } from '../../lib/devices';
import { lineChartSVG } from '../../lib/charts';

// Cap on copies rendered inline (hidden) for the client-side "Show everything"
// reveal. Average copies/version is ~1.4, but a handful of versions have
// hundreds — rendering those all into the DOM would bloat the page, so the
// overflow only renders on the ?all=1 server navigation.
const INLINE_COPY_CAP = 12;

const { id } = Astro.params;
const supabase = supabaseFor(Astro);
const rawParam = id as string;

// App Store ID in the URL preferred, then bundle_id, fallback to internal DB id.
const resolved = await resolveApp(supabase, rawParam);
const appData = resolved.app;
let dbError = resolved.dbError;

// A transient DB failure must not become a cached 404 (or a cached empty page).
if (dbError) {
  console.error('app page db failure for param:', rawParam);
  setDegraded(Astro.response);
}

if (!appData && !dbError) {
  return Astro.rewrite('/404');
}

// Wayback history is keyed by app_store_id — apps without one (delisted, no
// iTunesMetadata) simply don't get those sections.
const appStoreId = appData?.app_store_id ? Number(appData.app_store_id) : null;
const genreName = appData?.genres?.genre_name;

let versions: any[] = [];
let ipaFiles: any[] = [];
const binariesBySha1 = new Map<string, any>();
// icon sha → its perceptual-duplicate cluster canonical (icon_aliases). Used to
// pick each version's CONSENSUS icon: copies agree on the real icon, and a
// mis-extracted outlier (e.g. YouTube's Google "g" instead of the play button)
// is a lone different cluster that loses the vote.
const canonicalBySha = new Map<string, string>();

let chartHistory: any[] = [];
let ratingHistory: any[] = [];
let archivedReviews: any[] = [];
let reviewTotal = 0;
let chartTypesById = new Map<number, { name: string; slug: string }>();
let genreNamesMap: Map<number, string> = new Map();

let subgenre: string | null = null;
let moreFromDev: any[] = [];
let moreFromIcons: Map<number, string> | undefined;

// --- Data loading: four independent chains, run concurrently (this page used
// to await every stage in sequence — 8+ serial round trips of TTFB on a cold
// hit). Only the core chain may 503 the page; the other three are decorative
// and drop their section on failure.

// A. versions → archived copies → binary enrichment (each stage needs the last).
const loadCore = async () => {
  const versionsCacheKey = `versions:${appData.id}`;
  const cachedVersions = cacheGet<any[]>(versionsCacheKey);
  if (cachedVersions) {
    versions = cachedVersions;
  } else {
    const { data, error } = await supabase
      .from('app_versions')
      .select('id, version_string, build_number, minimum_os_version, release_date, estimated_release_date, external_identifier, device_family')
      .eq('app_id', appData.id)
      .order('release_date', { ascending: false })
      // 200 silently dropped the TAIL of the order — the oldest-dated versions
      // — for the 30+ apps with more (Instagram: 210, so 1.8.7 with the
      // original Polaroid icon vanished from the page while the sidebar,
      // computed DB-side over ALL versions, still showed it). Corpus max is
      // ~307; 1000 is PostgREST's hard cap anyway.
      .limit(1000);
    versions = data || [];
    if (error) {
      console.error('versions query failed:', error.message);
      dbError = true;
      setDegraded(Astro.response);
      return;
    }
    cacheSet(versionsCacheKey, versions, 5 * 60 * 1000);
  }

  const versionIds = versions.map((v: any) => v.id);
  if (!versionIds.length) return;
  // Bounded key (version sets change only at ingest); a cached empty array is a
  // hit, not a perpetual refetch.
  const ipaCacheKey = `ipa_files:${appData.id}:${versionIds.length}`;
  const cachedIpa = cacheGet<any[]>(ipaCacheKey);
  if (cachedIpa) {
    ipaFiles = cachedIpa;
  } else {
    const { data, error } = await supabase
      .from('ipa_files')
      .select('id, app_version_id, filename, file_size, md5_hash, has_itunes_metadata, info_plist_path, binary_sha1, available, archive_item_id, archive_items!ipa_files_archive_item_id_fkey(ia_item_id)')
      .in('app_version_id', versionIds);
    ipaFiles = data || [];
    if (error) {
      console.error('ipa files query failed:', error.message);
      dbError = true;
      setDegraded(Astro.response);
      return;
    }
    cacheSet(ipaCacheKey, ipaFiles, 5 * 60 * 1000);
  }
  if (!ipaFiles.length) return;

  // Binary enrichment (plan 009): install_status ("will it actually launch"),
  // architectures, and the icon extracted from the IPA itself. Keyed by content
  // hash — many mirrored files share one binaries row. No FK from
  // ipa_files.binary_sha1, so this is a second chunked lookup. Decorative: if
  // it fails, render the downloads without badges — never 503 the whole page.
  const shas = Array.from(new Set(ipaFiles.map((f: any) => f.binary_sha1).filter(Boolean)));
  const binCacheKey = `binaries:${appData.id}:${shas.length}`;
  let bins: any[] | null = cacheGet<any[]>(binCacheKey) ?? null;
  if (!bins) {
    bins = [];
    const CHUNK = 150; // keeps the in() filter well under URL-length limits
    for (let i = 0; i < shas.length; i += CHUNK) {
      const { data, error } = await supabase
        .from('binaries')
        .select('sha1, install_status, architectures, macho_min_os, itunes_artwork_sha256, bundle_icon_sha256, has_watch_app, has_extensions, hidden, retina_iphone, retina_ipad, retina_iphone_plus, device_family_macho')
        .in('sha1', shas.slice(i, i + CHUNK));
      if (error) {
        console.error('binaries query failed:', error.message);
        bins = null;
        break;
      }
      bins.push(...(data || []));
    }
    if (bins) cacheSet(binCacheKey, bins, 5 * 60 * 1000);
  }
  for (const b of bins || []) binariesBySha1.set(b.sha1, b);

  // Canonical cluster per icon (for per-version consensus). Best-effort: on any
  // failure, consensus falls back to the plain best-copy pick.
  const iconShas = Array.from(new Set((bins || [])
    .flatMap((b: any) => [b.bundle_icon_sha256, b.itunes_artwork_sha256]).filter(Boolean)));
  for (let i = 0; i < iconShas.length; i += 150) {
    const { data: al } = await supabase
      .from('icon_aliases')
      .select('sha256, canonical_sha256')
      .in('sha256', iconShas.slice(i, i + 150));
    for (const a of al || []) canonicalBySha.set(a.sha256, a.canonical_sha256);
  }
};

// B. Wayback time-machine history (plan 010 Phase 5): chart trajectory,
// rating history, and archived reviews — then the lookup-table labels the
// chart section needs. Each is independently best-effort.
const loadHistory = async () => {
  if (!appStoreId) return;
  const [charts, ratings, reviews] = await Promise.all([
    getAppChartHistory(supabase, appStoreId),
    getAppRatingHistory(supabase, appStoreId),
    getAppReviews(supabase, appStoreId, 8),
  ]);
  if (charts) chartHistory = charts;
  if (ratings) ratingHistory = ratings;
  if (reviews) {
    archivedReviews = reviews.rows;
    reviewTotal = reviews.total;
  }
  if (!chartHistory.length) return;
  // Labels for the chart-history section; if they fail, skip the section.
  const [types, genreNames] = await Promise.all([getChartTypes(supabase), getGenreNames(supabase)]);
  if (types && genreNames) {
    chartTypesById = new Map(types.map((t: any) => [Number(t.id), { name: t.name, slug: t.slug }]));
    genreNamesMap = genreNames;
  }
};

// C. Game subgenre (Arcade, Puzzle, …): Apple's game categories are the 7xxx
// genre codes recorded in archived listing snapshots. Only worth a lookup for
// games, and it's fine if there's no data (many apps have none).
const loadSubgenre = async () => {
  if (!appStoreId || genreName !== 'Games') return;
  const key = `subgenre:${appStoreId}`;
  const cached = cacheGet<string | null>(key);
  if (cached !== undefined) {
    subgenre = cached;
    return;
  }
  const { data } = await supabase
    .from('app_listing_snapshots')
    .select('genre_ids')
    .eq('app_store_id', appStoreId)
    .not('genre_ids', 'is', null)
    .limit(20);
  const counts = new Map<number, number>();
  for (const row of data || []) {
    for (const gid of (row as any).genre_ids || []) {
      const n = Number(gid);
      if (n >= 7000 && n < 8000) counts.set(n, (counts.get(n) || 0) + 1);
    }
  }
  let bestId: number | null = null;
  let bestN = 0;
  for (const [gid, n] of counts) if (n > bestN) { bestId = gid; bestN = n; }
  if (bestId != null) {
    const { data: g } = await supabase.from('genres').select('genre_name').eq('genre_id', bestId).maybeSingle();
    subgenre = (g as any)?.genre_name || null;
  }
  cacheSet(key, subgenre, 30 * 60 * 1000);
};

// D. Other apps by the same developer ("More from {developer}"), with their
// period-authentic (oldest) icons.
const loadMoreFromDev = async () => {
  if (!appData.developer_id) return;
  const key = `morefrom:${appData.developer_id}:${appData.id}`;
  const cached = cacheGet<any[]>(key);
  if (cached) {
    moreFromDev = cached;
  } else {
    const { data } = await supabase
      .from('apps')
      .select('id, app_store_id, app_store_name, display_name, bundle_id, icon_url:live_icon_url, version_count')
      .eq('developer_id', appData.developer_id)
      .neq('id', appData.id)
      .not('excluded', 'is', true)
      .order('version_count', { ascending: false })
      .limit(12);
    moreFromDev = data || [];
    cacheSet(key, moreFromDev, 10 * 60 * 1000);
  }
  if (moreFromDev.length) moreFromIcons = await getOldestIcons(supabase, moreFromDev.map((a: any) => Number(a.id)));
};

// E. Period-authentic screenshots: the distinct screenshot SETS across the
// listing's archived life. Each set is fully recovered (every shot durable in
// R2 → /screen/<sha>), in original page order (devs composed panorama sets, so
// order is load-bearing), labeled with its capture date and the version live
// then. The earliest set shows by default; a picker (JS) browses the history.
// get_app_screenshots does the exact + near-duplicate dedup and iPhone-prefer
// server-side (the snapshot_screenshots view is too slow filtered by one app).
// Strip height is fixed (SHOT_H); each shot's box width is derived from its
// master's aspect ratio so the flex slot reserves the right space BEFORE the
// image loads — otherwise width:auto collapses to ~0 and the strip jumps as
// images arrive. Portrait iPhone default when a master lacks dimensions.
const SHOT_H = 260;
type Shot = { src: string; w: number };
type ShotSet = { date: string; label: string; version: string | null; shots: Shot[] };
let screenshotSets: ShotSet[] = [];
const loadScreenshots = async () => {
  if (!appStoreId) return;
  const key = `shotsets:v2:${appStoreId}`;   // v2: shots carry box width
  const cached = cacheGet<ShotSet[]>(key);
  if (cached) { screenshotSets = cached; return; }
  const { data, error } = await supabase.rpc('get_app_screenshots', {
    p_app_store_id: appStoreId,
    p_max_sets: 40,
  });
  if (error) { console.error('screenshots rpc failed:', error.message); return; }
  screenshotSets = (data || [])
    .map((row: any) => ({
      date: row.captured_at,
      label: formatMonthYear(row.captured_at),
      version: row.version_string || null,
      shots: (row.shots || [])
        .map((s: any) => {
          if (!s || !s.sha) return null;
          const w = Number(s.w), h = Number(s.h);
          const boxW = w > 0 && h > 0 ? Math.round(SHOT_H * w / h) : Math.round(SHOT_H * 0.5625);
          return { src: `/screen/${s.sha}`, w: boxW };
        })
        .filter(Boolean) as Shot[],
    }))
    .filter((s: ShotSet) => s.shots.length > 0);
  cacheSet(key, screenshotSets, 30 * 60 * 1000);
};
const setLabel = (s: ShotSet) => s.label + (s.version ? ` · v${s.version}` : '');

if (appData) {
  await Promise.all([loadCore(), loadHistory(), loadSubgenre(), loadMoreFromDev(), loadScreenshots()]);
}

// Fold raw chart rows into one group per (chart type, device, genre): peak,
// span, and a chronological trajectory for the sparkline.
let chartGroups: any[] = [];
if (!dbError && chartHistory.length && chartTypesById.size) {
  const groups = new Map<string, any>();
  for (const row of chartHistory) {
    const snap = row.chart_snapshots;
    if (!snap) continue;
    const device = deviceOf(snap.source_url || '');
    const genreId = snap.genre_id == null ? null : Number(snap.genre_id);
    const typeId = Number(snap.chart_type_id);
    const key = `${typeId}:${device}:${genreId ?? 'all'}`;
    let g = groups.get(key);
    if (!g) {
      g = { typeId, device, genreId, points: [] };
      groups.set(key, g);
    }
    g.points.push({
      date: snap.snapshot_date,
      position: Number(row.position),
    });
  }
  for (const g of groups.values()) {
    // One point per date (duplicate captures of the same feed) — best rank wins.
    g.points.sort((a: any, b: any) => a.date.localeCompare(b.date) || a.position - b.position);
    const byDate = new Map<string, any>();
    for (const p of g.points) if (!byDate.has(p.date)) byDate.set(p.date, p);
    g.points = Array.from(byDate.values());
    g.peak = Math.min(...g.points.map((p: any) => p.position));
    g.peakDate = g.points.find((p: any) => p.position === g.peak)?.date;
    g.first = g.points[0].date;
    g.last = g.points[g.points.length - 1].date;
  }
  chartGroups = Array.from(groups.values()).sort(
    (a, b) => Number(a.genreId != null) - Number(b.genreId != null) || b.points.length - a.points.length || a.peak - b.peak
  );
}

// The listing snapshots mix storefronts and rating bases: a US all-versions
// total (millions) sits next to a small non-US storefront capture or an
// Apple "this version only" count (thousands), so a raw plot whiplashes between
// them. An app's all-versions total only grows over time, so we keep a
// monotonic envelope — drop any capture whose count falls well below the
// highest established level (those are the non-US / current-version outliers),
// while still allowing the count to climb.
let ratingMax = 0;
const ratingEnvelope = (ratingHistory || []).filter((r: any) => {
  const c = Number(r.rating_count);
  if (!Number.isFinite(c) || c <= 0) return r.rating_count == null; // keep count-less avg points
  if (ratingMax > 0 && c < ratingMax * 0.5) return false;          // storefront/current-version dip
  if (c > ratingMax) ratingMax = c;
  return true;
});
// Rating snapshots arrive in bursts (several captures of the same listing
// state) — collapse identical consecutive states, then thin to a readable table.
const ratingRows = sampleEvenly(
  ratingEnvelope.filter((r: any, i: number) => {
    if (i === 0) return true;
    const prev = ratingEnvelope[i - 1];
    return !(r.version === prev.version && r.rating_count === prev.rating_count && r.rating_avg === prev.rating_avg);
  }),
  15
);

// Dead archive.org copies (available=false) never render a button; a version
// whose every copy is dead says so instead of "no file".
// Quarantined copies (re-signed/tweak-injected/wrapper repackages that reuse a
// real bundle id — see the Colophon's "What belongs in the archive") are
// dropped outright via binaries.hidden (a DB-generated column, the single
// definition of the quarantine set): editorial suppression, so unlike
// encrypted-only versions they do NOT come back under "Show everything".
// Unclassified binaries (hidden=false) pass; a hidden binary is recoverable by
// reclassifying to 'clean', which un-hides it everywhere at once.
const filesByVersionId = new Map<number, any[]>();
const unavailableCountByVersion = new Map<number, number>();
for (const f of ipaFiles) {
  if (f.available === false) {
    unavailableCountByVersion.set(f.app_version_id, (unavailableCountByVersion.get(f.app_version_id) || 0) + 1);
    continue;
  }
  if (f.binary_sha1 && binariesBySha1.get(f.binary_sha1)?.hidden) continue;
  const arr = filesByVersionId.get(f.app_version_id) || [];
  arr.push(f);
  filesByVersionId.set(f.app_version_id, arr);
}

const binaryOf = (f: any) => (f?.binary_sha1 ? binariesBySha1.get(f.binary_sha1) : undefined);

// A version's icon is the build-time bundle icon it declared (period-accurate,
// on-device truth). We deliberately do NOT fall back to itunes_artwork_sha256 (iTunesArtwork
// = the App Store LISTING icon, a separate and sometimes hand-differed artifact);
// a version with no loose bundle icon (iOS7+ Assets.car) falls back to a SIBLING
// version's bundle icon instead — see vIconSha. Content-addressed at /icon/<sha>.
const iconShaOf = (f: any) => binaryOf(f)?.bundle_icon_sha256 || null;

// The consensus icon for a version: group its copies' icons by perceptual
// cluster (icon_aliases canonical) and take the cluster the most copies agree
// on, weighting encrypted copies (untamperable ground truth) double. A lone
// mis-extraction — YouTube's Google "g", Google+'s play-slash — is its own
// 1-vote cluster and loses to the real icon. Ties/singletons keep the plain
// best-copy order. Returns a concrete sha (the best copy's icon in the winning
// cluster), which /icon then canonicalizes.
function consensusIconSha(files: any[]): string | null {
  const byCluster = new Map<string, { weight: number; sha: string }>();
  for (const f of files) {
    const bin = binaryOf(f);
    const sha = bin?.bundle_icon_sha256;      // bundle icon only — never store artwork
    if (!sha) continue;
    const cluster = canonicalBySha.get(sha) || sha;
    const w = bin?.install_status === 'encrypted' ? 2 : 1;
    const cur = byCluster.get(cluster);
    if (!cur) byCluster.set(cluster, { weight: w, sha });
    else { cur.weight += w; if (bin?.bundle_icon_sha256 && cur.sha !== bin.bundle_icon_sha256) cur.sha = bin.bundle_icon_sha256; }
  }
  let best: { weight: number; sha: string } | null = null;
  for (const c of byCluster.values()) if (!best || c.weight > best.weight) best = c;
  return best?.sha ?? null;
}

// The app header shows the OLDEST archived icon (period-authentic) extracted
// from the app's own binaries, before falling back to the iTunes CDN icon_url.
// Prefer the precomputed apps.oldest_icon_sha256: unlike the local raw-earliest
// pick below, the SQL job behind it favors an icon CLUSTER that recurs across
// versions — so a single counterfeit copy planted at the app's earliest version
// (the "Talking Tom diva" case) can't hijack the hero icon — and it re-checks
// binaries.hidden hourly. The local pick remains as the fallback for apps the
// cron hasn't stamped yet. (Time-scoped surfaces — version rows, Time Machine —
// instead show the icon closest to that moment.)
const oldestIconSha = appData?.oldest_icon_sha256 || pickOldestIcon(
  (versions || []).flatMap((v: any) =>
    (filesByVersionId.get(v.id) || []).map((f: any) => {
      const bin = binaryOf(f);
      return {
        version_string: v.version_string,
        minimum_os_version: v.minimum_os_version,
        bundle_icon_sha256: bin?.bundle_icon_sha256 || null,
        install_status: bin?.install_status,
        architectures: bin?.architectures,
        has_extensions: bin?.has_extensions,
      };
    })
  )
);

const installableVersionCount = (versions || []).filter((v: any) =>
  (filesByVersionId.get(v.id) || []).some((f: any) => binaryOf(f)?.install_status === 'installable')
).length;

const anyMultiCopy = (versions || []).some(
  (v: any) => dedupeFilesByHash(filesByVersionId.get(v.id) || []).length > 1
);

// Bulk-imported versions share one bogus release_date (e.g. 487 versions
// catalog-wide claim "Apr 1, 2010"). Real releases don't land 3+ versions on
// the same day, so a date that repeats that often within this app is an
// import artifact — hide it.
const dateCounts = new Map<string, number>();
// A release_date is the iTunes *original*-release stamp (not a per-version date)
// whenever some version carrying it has its own, different estimated date. That
// contradiction proves the value is a shared placeholder — e.g. Shazam stamps
// "2008-07-07" on both 1.0 (whose real estimate is 2008-08-27) and 1.5.3 (no
// estimate). The bare <3 count misses it when the stamp lands on only two
// versions, which then sorts 1.5.3 *before* 1.0. Distrust such values so the
// undated version interpolates by ext-id/version instead of inheriting a date
// that predates a lower-numbered sibling.
const contradictedDates = new Set<string>();
for (const v of versions || []) {
  // Key on the calendar day, not the full timestamp — a bulk-imported date
  // reused across versions is the artifact we want to catch even when the times
  // differ slightly.
  const d = v?.release_date ? String(v.release_date).slice(0, 10) : null;
  if (d) {
    dateCounts.set(d, (dateCounts.get(d) || 0) + 1);
    const est = v?.estimated_release_date ? String(v.estimated_release_date).slice(0, 10) : null;
    if (est && est !== d) contradictedDates.add(d);
  }
}
const isTrustworthyDate = (d: any) => {
  if (!d) return false;
  const key = String(d).slice(0, 10);
  return (dateCounts.get(key) || 0) < 3 && !contradictedDates.has(key);
};

// A date can't precede the iOS release its binary requires: iMovie 1.2.2 (stored
// as "122") needs iOS 5.0 yet carried a bulk-artifact release_date of Jun 2010 —
// two years before iOS 5 existed. Reject any displayed date earlier than the
// min-OS's release year (year floor is conservative, so it only rejects the
// clearly-impossible, never a plausibly-early one).
const OS_RELEASE_YEAR: Record<number, number> = {
  2: 2008, 3: 2009, 4: 2010, 5: 2011, 6: 2012, 7: 2013, 8: 2014, 9: 2015,
  10: 2016, 11: 2017, 12: 2018, 13: 2019, 14: 2020, 15: 2021, 16: 2022, 17: 2023, 18: 2024,
};
function datePlausible(dateStr: any, v: any): boolean {
  if (!dateStr) return false;
  const yr = parseInt(String(dateStr).slice(0, 4), 10);
  if (!Number.isFinite(yr)) return false;
  const major = parseInt(String(v?.minimum_os_version || '').split('.')[0], 10);
  const floor = Number.isFinite(major) ? OS_RELEASE_YEAR[major] : undefined;
  return !floor || yr >= floor;
}

const requestUrl = new URL(Astro.request.url);
const pathname = requestUrl.pathname;
const searchParams = requestUrl.searchParams;
const origin = requestUrl.origin;

// Versions are always sorted by date; only the direction toggles. The default
// server representation — the one that edge-caches for everyone — is oldest
// first (the preservation view). Legacy iOS devices, the archive's actual
// target hardware, instead get newest-first with their OS filter preset; that
// happens via a one-time client redirect to ?dir=desc&ios=<major> (see the
// inline script below), so the default stays device-agnostic and cacheable.
const currentDir = coerceDir(searchParams.get('dir') || 'asc');

// The page is rendered identically for every device (no User-Agent sniffing),
// so it edge-caches. The old auto "hide newer than your iOS" filter is now an
// explicit ?ios=<major> choice — a distinct, cacheable URL per selection.
if (!dbError) setCacheHeaders(Astro.response, 3600);

// By default we show only installable, available versions (best copy each).
// ?all=1 ("Show everything") reveals every copy, plus unavailable and
// encrypted-only versions.
const showEverything = searchParams.get('all') === '1';
function everythingHref(on: boolean): string {
  const sp = new URLSearchParams(searchParams);
  if (on) sp.set('all', '1');
  else sp.delete('all');
  const q = sp.toString();
  return q ? `${pathname}?${q}` : pathname;
}

// Compatibility filter: ?ios=6 keeps versions that run on an iOS 6-class device
// (minimum OS major ≤ 6), plus any version whose minimum is unknown.
const minOsMajor = (v: any) => {
  const m = parseInt(String(v?.minimum_os_version || '').split('.')[0], 10);
  return Number.isFinite(m) && m > 0 ? m : null;
};
const iosParam = searchParams.get('ios');
const iosFilter = iosParam && /^\d{1,2}$/.test(iosParam) ? Number(iosParam) : null;
const iosMajors = Array.from(
  new Set((versions || []).map(minOsMajor).filter((m): m is number => m != null))
).sort((a, b) => a - b);
function iosFilterHref(major: number | null): string {
  const sp = new URLSearchParams(searchParams);
  if (major == null) sp.delete('ios');
  else sp.set('ios', String(major));
  const q = sp.toString();
  return q ? `${pathname}?${q}` : pathname;
}

const filtered = iosFilter == null
  ? (versions || [])
  : (versions || []).filter((v: any) => { const mm = minOsMajor(v); return mm == null || mm <= iosFilter; });

// Chronological key source: the estimated date, else a trustworthy release_date
// (day precision). Undated versions get placed by ext id / version number.
const chronoDateOf = (v: any) =>
  (v?.estimated_release_date && datePlausible(v.estimated_release_date, v))
    ? String(v.estimated_release_date).slice(0, 10)
    : (isTrustworthyDate(v?.release_date) && datePlausible(v.release_date, v) ? String(v.release_date).slice(0, 10) : null);
const sortedVersions = sortVersions(filtered, currentDir, chronoDateOf);

// Flip the sort direction, preserving the other params.
function sortToggleHref(): string {
  const sp = new URLSearchParams(searchParams);
  sp.set('dir', currentDir === 'asc' ? 'desc' : 'asc');
  return `${pathname}?${sp.toString()}`;
}

const appTitle = appData ? appTitleOf(appData) : 'App';
// The header is a STORE-LISTING surface: the period store showed the 512px
// artwork there, never a blown-up 57px bundle icon. large_icon_sha256 is the
// highest-res member of the oldest icon's perceptual cluster (cluster
// membership = same-design proof) or a verified icon_upgrades master; ?exact
// stops /icon from bouncing a non-canonical member back to the small
// canonical. Version rows keep strict bundle-origin shas.
const largeIconSha = appData?.large_icon_sha256;
const appIcon = largeIconSha ? `/icon/${largeIconSha}?exact`
  : oldestIconSha ? `/icon/${oldestIconSha}`
  : (appData ? iconSrc(appData.icon_url) : '');
// A small source blown up to 175px smears; at ≥2× integer-ish scale, honest
// pixels read as deliberately retro instead. 90px ≈ the 2× cutoff.
const appIconPixelated = !!appIcon && (appData?.large_icon_px ?? 175) <= 90;
const developerName = appData?.developers?.artist_name;
const versionNoun = versions.length === 1 ? 'archived version' : 'archived versions';

// --- Left-rail product lockup (iTunes Preview style) -----------------------

// Star row for the era rating widget: full / half stars, invisible "ghost"
// placeholders for the rest (matching the original markup exactly).
function starSpans(avg: number): string[] {
  const out: string[] = [];
  const rounded = Math.round(avg * 2) / 2;
  for (let i = 1; i <= 5; i++) {
    if (rounded >= i) out.push('rating-star');
    else if (rounded >= i - 0.5) out.push('rating-star half');
    else out.push('rating-star ghost');
  }
  return out;
}

// Latest archived listing state → the lockup's price + Customer Ratings box.
const latestRating = ratingHistory.length ? ratingHistory[ratingHistory.length - 1] : null;
const lockupPrice = latestRating ? formatPrice(latestRating.price_amount, latestRating.price_currency) : null;
const lockupStars = latestRating?.rating_avg != null ? starSpans(Number(latestRating.rating_avg)) : null;
const lockupStarsLabel = latestRating?.rating_avg != null ? `${Number(latestRating.rating_avg).toFixed(1)} stars` : '';

// "Compatible with …. Requires iOS X or later" from the archived versions.
const familySet = new Set<string>();
for (const v of versions || []) for (const d of v.device_family || []) familySet.add(String(d));
const isUniversalApp = familySet.has('1') && familySet.has('2');
const compatDevices = isUniversalApp
  ? 'iPhone, iPod touch, and iPad'
  : familySet.has('2') ? 'iPad' : 'iPhone and iPod touch';
const requirementsText = `Compatible with ${compatDevices}.${iosMajors.length ? ` Requires iOS ${iosMajors[0]}.0 or later.` : ''}`;

// One archived copy of a version → its display detail + download affordances.
function describeCopy(f: any, withFilename: boolean) {
  const bin = binaryOf(f);
  const size = formatFileSize(f.file_size);
  const detailBits = withFilename ? [fileLabel(f.filename), size] : [size];
  if (bin?.has_watch_app) detailBits.push('Watch app');
  let ipaUrl: string | null = null;
  try {
    ipaUrl = generateIpaDownloadUrl({
      id: f.id,
      filename: f.filename,
      info_plist_path: f.info_plist_path,
      archive_item: { ia_item_id: f.archive_items?.ia_item_id || '' },
    });
  } catch {
    ipaUrl = null;
  }
  return {
    detail: detailBits.filter(Boolean).join(' · '),
    encrypted: bin?.install_status === 'encrypted',
    ipaUrl,
    manifestUrl: `${origin}/manifest/${f.id}.plist`,
  };
}

// The best copy fronts the lockup (its stats stacked under the meta, its button
// centered opposite); the rest are extra copies revealed by "Show all copies".
const versionRows = (sortedVersions || []).map((v: any) => {
  const groups = sortGroupsByPreference(
    dedupeFilesByHash(filesByVersionId.get(v.id) || []),
    binaryOf,
    v.minimum_os_version
  );
  const inlineGroups = showEverything ? groups : groups.slice(0, INLINE_COPY_CAP);
  // Hidden unless "Show everything": versions with no available copy, or whose
  // only copies are FairPlay-encrypted (install but won't launch).
  const hasInstallable = groups.some((g: any) => binaryOf(g.file)?.install_status === 'installable');
  const hideByDefault = !hasInstallable;
  // A version whose only archived copies are FairPlay-encrypted (they install
  // but won't launch) — no usable install exists. Its icon is dimmed to signal
  // that. Distinct from "no file at all" (groups.length === 0).
  const encryptedOnly = groups.length > 0
    && groups.every((g: any) => binaryOf(g.file)?.install_status === 'encrypted');
  const versionLabel = v.version_string || v.build_number || 'Unknown version';
  const showBuild = v.build_number && v.build_number !== versionLabel;
  // Consensus across this version's copies (all of them, not just the deduped
  // display groups), so a lone mis-extracted icon can't win by sorting first.
  // Null here (Assets.car version, no loose bundle icon) is filled from the
  // NEAREST icon-bearing sibling version in the timeline pass below.
  const vIconSha = consensusIconSha(filesByVersionId.get(v.id) || [])
    || groups.map((g: any) => iconShaOf(g.file)).find(Boolean)
    || null;
  const bin0 = groups.map((g: any) => binaryOf(g.file)).find(Boolean);
  const machoMinOs = bin0?.macho_min_os;
  // Each compatibility fact gets its own stacked line (OS requirement + date;
  // the CPU-architecture line was cut — the iOS requirement is enough).
  const metaLines: { text: string; title?: string; retina?: boolean }[] = [];
  const osReq = osRequirementLabel(v.minimum_os_version) || osRequirementLabel(machoMinOs);
  if (osReq) metaLines.push({ text: osReq });
  // Universal (iPhone + iPad) → the App Store's "fat binary" + badge.
  const df = (v.device_family || []).map((x: any) => String(x));
  // Retina support, per idiom (plan 013). The binary's own UIDeviceFamily
  // (device_family_macho) is authoritative for which idioms the build targets —
  // the App Store metadata device_family is often missing for archived apps —
  // so prefer it, falling back to the version's when absent.
  const binFam = (bin0?.device_family_macho || []).map((x: any) => String(x));
  const retina = retinaLabel(bin0, binFam.length ? binFam : df);
  if (retina) metaLines.push({ ...retina, retina: true });
  if (v.estimated_release_date && datePlausible(v.estimated_release_date, v)) metaLines.push({ text: formatDate(v.estimated_release_date), title: 'Estimated release date' });
  else if (isTrustworthyDate(v.release_date) && datePlausible(v.release_date, v)) metaLines.push({ text: `Released ${formatDate(v.release_date)}` });
  const minosMajor = minOsMajor(v) ?? (machoMinOs ? parseInt(String(machoMinOs).split('.')[0], 10) : null);
  const isUniversal = df.indexOf('1') >= 0 && df.indexOf('2') >= 0;
  const multi = groups.length > 1;
  const primary = inlineGroups[0] ? describeCopy(inlineGroups[0].file, false) : null;
  const extras = inlineGroups.slice(1).map((g: any) => describeCopy(g.file, multi));
  const nofileText = groups.length === 0
    ? (unavailableCountByVersion.get(v.id)
        ? 'This version is no longer available on archive.org'
        : 'No file in the archive for this version')
    : null;
  return { v, versionLabel, showBuild, vIconSha, metaLines, minosMajor, isUniversal, hideByDefault, encryptedOnly, primary, extras, nofileText };
});

// Assets.car versions (no loose bundle icon of their own) borrow the NEAREST
// sibling's bundle icon along the timeline: the latest earlier icon-bearing
// version, else the earliest later one. Nearest beats app-oldest — a 2017
// version must not wear the 2010 icon — and it's always a real bundle icon
// from this app, never the store artwork. Only apps that never shipped a
// loose icon at all go without (→ header's app-level icon_url).
{
  const rowById = new Map(versionRows.map((r: any) => [r.v.id, r]));
  const chronoRows = sortVersions(filtered, 'asc', chronoDateOf)
    .map((v: any) => rowById.get(v.id))
    .filter(Boolean);
  let carry: string | null = null;
  for (const r of chronoRows) { if (r.vIconSha) carry = r.vIconSha; else r.vIconSha = carry; }
  carry = null;
  for (let i = chronoRows.length - 1; i >= 0; i--) {
    const r = chronoRows[i];
    if (r.vIconSha) carry = r.vIconSha; else r.vIconSha = carry;
  }
}

// The Retina/Non-Retina marker only earns its place as a contrast. If every
// version reads as full "Retina" (no non-Retina and no idiom-asymmetric build),
// the badge is redundant on each row — drop it app-wide. Any variation
// (Non-Retina, or Retina on one idiom only) keeps all the markers so the
// distinction stays legible.
const anyNonFullRetina = versionRows.some((r: any) =>
  r.metaLines.some((l: any) => l.retina && l.text !== 'Retina')
);
if (!anyNonFullRetina) {
  for (const r of versionRows) r.metaLines = r.metaLines.filter((l: any) => !l.retina);
}

const shownByDefaultCount = versionRows.filter((r: any) => !r.hideByDefault).length;

// Bundle size over time — the largest copy per dated version, chronological.
// Uses every version (not the current sort/filter) so the trend is complete.
const sizePoints = (versions || [])
  .map((v: any) => {
    // Encrypted copies are excluded — they're not a real installable size.
    const files = (filesByVersionId.get(v.id) || []).filter((f: any) => binaryOf(f)?.install_status !== 'encrypted');
    const bytes = files.reduce((mx: number, f: any) => Math.max(mx, Number(f.file_size) || 0), 0);
    const dateStr = (v.estimated_release_date && datePlausible(v.estimated_release_date, v)) ? v.estimated_release_date
      : (isTrustworthyDate(v.release_date) && datePlausible(v.release_date, v) ? v.release_date : null);
    const t = dateStr ? Date.parse(dateStr) : NaN;
    return { t, y: bytes, dateStr };
  })
  .filter((p: any) => Number.isFinite(p.t) && p.y > 0)
  .sort((a: any, b: any) => a.t - b.t);

let sizeChart = '';
if (sizePoints.length >= 3) {
  sizeChart = lineChartSVG(
    sizePoints.map((p: any) => ({ t: p.t, y: p.y, label: `${formatFileSize(p.y)} — ${formatDate(p.dateStr)}` })),
    {
      title: 'Bundle size over time',
      yFormat: (n: number) => formatFileSize(n),
      xStartLabel: formatMonthYear(sizePoints[0].dateStr),
      xEndLabel: formatMonthYear(sizePoints[sizePoints.length - 1].dateStr),
    }
  );
}
---

<Layout
  title={`${appTitle} — Legacy Store`}
  activeTab="none"
  description={appData ? `${appTitle}${developerName ? ` by ${developerName}` : ''} — ${versions.length} ${versionNoun} for old iOS devices, installable directly on iPhone, iPad, and iPod touch.` : 'Legacy Store'}
  canonicalPath={appData ? `/app/${appData.app_store_id || appData.id}` : ''}
>
    {dbError ? (
      <DbError />
    ) : (
      <>
        {/* Legacy-device default: the page renders oldest-first for everyone (so
            it edge-caches), but an actual vintage iOS device wants the newest
            build it can run at the top. On a fresh visit (no explicit sort yet)
            redirect such a device once to the newest-first, OS-filtered view.
            Both params then live in the URL, so this never re-fires and the
            toggle/filter render consistently server-side. Runs before the list
            paints; old-WebKit-safe (no ES6). Modern iOS + desktop keep the
            oldest-first default. */}
        <script is:inline>
          (function () {
            try {
              var ua = navigator.userAgent;
              if (!/iPhone|iPad|iPod/.test(ua)) return;
              var m = ua.match(/OS (\d+)_/);
              if (!m) return;
              var major = parseInt(m[1], 10);
              var LEGACY_IOS_MAX = 12; /* iOS <=12 ~ real vintage hardware; 13+ is modern */
              if (!(major > 0 && major <= LEGACY_IOS_MAX)) return;
              var s = location.search;
              if (/[?&]dir=/.test(s)) return; /* user already chose a sort */
              var add = 'dir=desc';
              if (!/[?&]ios=/.test(s)) add += '&ios=' + major;
              location.replace(location.pathname + s + (s ? '&' : '?') + add);
            } catch (e) {}
          })();
        </script>

        {/* iOS-only jailbreak notice — shown exactly when the Install button is
            (i.e. everywhere the Download button ISN'T), so it mirrors the
            .navbtn-install visibility rule in the is:global block below. */}
        <div class="jb-notice">To install apps directly onto this device, it must be jailbroken with AppSync installed.</div>

        {/* Title lockup — h1 + "By developer", as on the original preview page */}
        <div id="title" class="intro">
          <h1>{appTitle}</h1>
          {developerName && (
            <h2>By {appData.developer_id
              ? <a href={`/developer/${appData.developer_id}`}>{developerName}</a>
              : developerName}</h2>
          )}
          {appData.developer_id && (
            <a class="view-more" href={`/developer/${appData.developer_id}`}>View More By This Developer</a>
          )}
        </div>

        {/* Left rail: the product lockup (artwork + metadata) and, when the
            Wayback data has one, the era Customer Ratings box. */}
        <div id="left-stack">
          <div class="lockup product application">
            <div class="artwork">
              {appIcon ? <><img src={appIcon} width="175" height="175" class={appIconPixelated ? 'artwork artwork-pixelated' : 'artwork'} alt={appTitle} /><span class="mask"></span></> : null}
            </div>
            {isUniversalApp && (
              <div class="fat-binary-blurb"><span class="fat-binary-badge">&nbsp;</span><span>This app is designed for both iPhone and iPad</span></div>
            )}
            <ul class="list">
              {lockupPrice && <li><div class="price">{lockupPrice}</div></li>}
              {genreName && appData.genre_id && (
                <li class="genre"><span class="label">Category: </span><a href={`/categories/${appData.genre_id}`}>{genreName}</a></li>
              )}
              {subgenre && <li class="genre"><span class="label">Subgenre: </span>{subgenre}</li>}
              {appData.original_release_date && (
                <li title="When the app first appeared on the App Store (may predate our earliest archived copy)">
                  <span class="label">First released: </span>{formatDate(appData.original_release_date)}</li>
              )}
              <li><span class="label">Versions: </span>{versions.length} archived</li>
              {installableVersionCount > 0 && (
                <li><span class="label">Installable: </span>{installableVersionCount} of {versions.length}</li>
              )}
              {developerName && <li><span class="label">Seller: </span>{developerName}</li>}
              <li class="copyright" title={appData.bundle_id}>{appData.bundle_id}</li>
            </ul>
            <p><span class="app-requirements">Requirements: </span>{requirementsText}</p>
          </div>

          {lockupStars && (
            <div class="extra-list customer-ratings">
              <h4>Customer Ratings</h4>
              {latestRating?.captured_at && <div class="ratings-asof">As of {formatDate(latestRating.captured_at)}</div>}
              <div class="rating" role="text" aria-label={lockupStarsLabel}>
                <div>
                  {lockupStars.map((cls) => <span class={cls}>&nbsp;</span>)}
                </div>
                {latestRating.rating_count != null && (
                  <span class="rating-count">{formatNumber(latestRating.rating_count)} Ratings</span>
                )}
              </div>
            </div>
          )}
        </div>

        <div class="center-stack">
        {screenshotSets.length > 0 && (
          <div class="screenshots" aria-label="Screenshots">
            <div class="shots-head">
              {screenshotSets.length > 1 ? (
                <label class="shots-pick-wrap">
                  <span class="shots-pick-label">Listing from</span>
                  {/* The <select> is itself the date/version label. Disabled
                      until JS enables it, so no-JS users see the (accurate)
                      caption for the one set they can see, not a dead control. */}
                  <select class="shots-picker js-shots-picker" disabled>
                    {screenshotSets.map((s, i) => (
                      <option value={String(i)}>{setLabel(s)}</option>
                    ))}
                  </select>
                </label>
              ) : (
                <span class="shots-caption">{setLabel(screenshotSets[0])}</span>
              )}
            </div>
            {screenshotSets.map((s, i) => (
              <div class={i === 0 ? 'shot-set is-active' : 'shot-set'} data-shot-set={String(i)}>
                <div class="shots-strip">
                  {s.shots.map((sh) => (
                    <a class="shot" href={sh.src} target="_blank" rel="noopener" style={`width:${sh.w}px`}>
                      <img src={sh.src} width={sh.w} height={SHOT_H} loading="lazy" alt="Screenshot" />
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}
        <div class="filter-bar">
          <a class="filter-chip" href={sortToggleHref()}>Sort by Date <span class="sort-tri">{currentDir === 'asc' ? '▴' : '▾'}</span></a>
          {iosMajors.length > 1 && (
            <form class="filter-runs" method="get" action={pathname}>
              {currentDir === 'desc' && <input type="hidden" name="dir" value="desc" />}
              {showEverything && <input type="hidden" name="all" value="1" />}
              <label class="filter-label">Runs on
                <select name="ios" class="js-ios-select">
                  <option value="" selected={iosFilter == null}>Any</option>
                  {iosMajors.map((m) => (
                    <option value={String(m)} selected={iosFilter === m}>{osShortLabel(m)}</option>
                  ))}
                </select>
              </label>
              <noscript><button type="submit" class="filter-go">Go</button></noscript>
            </form>
          )}
          <a
            class="filter-chip js-everything-toggle"
            href={everythingHref(!showEverything)}
            data-expand="Show everything"
            data-collapse="Show best only"
          >{showEverything ? 'Show best only' : 'Show everything'}</a>
        </div>

        <div class={showEverything ? 'versions show-everything' : 'versions'}>
          {versionRows.map((row: any) => (
            <div class={row.hideByDefault ? 'version v-hidden-default' : 'version'} id={`v${row.v.id}`} data-minos={row.minosMajor != null && row.minosMajor > 0 ? String(row.minosMajor) : undefined} data-copies={row.extras.length > 0 ? String(row.extras.length + 1) : undefined}>
              {/* Lockup: masked icon + stacked title/meta on the left; the best
                  copy's action button opposite, with size + badge stacked under
                  it. Universal apps get the fat-binary "+" on the button. */}
              <div class="v-lockup">
                <span class={row.encryptedOnly ? 'v-icon v-dim' : 'v-icon'}>{row.vIconSha ? <><img src={`/icon/${row.vIconSha}`} alt="" loading="lazy" /><span class="icon-mask"></span></> : null}</span>
                <div class="v-body">
                  <div class="v-title">
                    <strong>{row.versionLabel}</strong>
                    {row.showBuild && <span class="v-build"> ({row.v.build_number})</span>}
                  </div>
                  {row.metaLines.map((l: any) => (
                    <div class="v-fact" title={l.title}>{l.text}</div>
                  ))}
                  {row.nofileText && <div class="v-fact v-nofile">{row.nofileText}</div>}
                </div>
                {row.primary ? (
                  // Size sits to the LEFT of the button so the button stays
                  // right-aligned across every row; the "N more copies" affordance
                  // lives in the freed space under the button.
                  <span class="file-actions">
                    <span class="fa-line">
                      <span class="fa-meta">
                        {row.primary.detail && <span class="file-stat-size">{row.primary.detail}</span>}
                        {!row.primary.ipaUrl && <span class="file-stat-size">File source unavailable</span>}
                        {row.primary.encrypted && <span class="chip chip-warn">Encrypted</span>}
                      </span>
                      {row.primary.ipaUrl ? (
                        <span class="file-buttons">
                          <a class={`wsfbtn wsfbtn-primary navbtn-install${row.isUniversal ? ' nav-universal' : ''}`} href={`itms-services://?action=download-manifest&url=${encodeURIComponent(row.primary.manifestUrl)}`}>Install</a>
                          <a class={`wsfbtn navbtn-alt${row.isUniversal ? ' nav-universal' : ''}`} href={row.primary.ipaUrl} download>Download</a>
                        </span>
                      ) : (
                        <span class="file-buttons"><span class="wsfbtn wsfbtn-disabled" aria-disabled="true">Download</span></span>
                      )}
                    </span>
                    {row.extras.length > 0 && (
                      <span class="more-copies">{row.extras.length} more {row.extras.length === 1 ? 'copy' : 'copies'} <span class="mc-tri">&#8250;</span></span>
                    )}
                  </span>
                ) : (
                  // No available copy: still show a (disabled) action so the row reads consistently.
                  <span class="file-actions">
                    <span class="fa-line"><span class="file-buttons"><span class="wsfbtn wsfbtn-disabled" aria-disabled="true">Download</span></span></span>
                  </span>
                )}
              </div>
              {row.extras.length > 0 && (
                <div class="v-copies">
                  {row.extras.map((c: any) => (
                    <div class="file-row v-extra">
                      <span class="file-detail">
                        {c.detail && <span class="file-name">{c.detail}</span>}
                        {!c.ipaUrl && <span class="file-name">File source unavailable</span>}
                        {c.encrypted && <span class="file-chip"><span class="chip chip-warn">Encrypted</span></span>}
                      </span>
                      {c.ipaUrl && (
                        <span class="file-actions">
                          <span class="file-buttons">
                            <a class={`wsfbtn wsfbtn-primary navbtn-install${row.isUniversal ? ' nav-universal' : ''}`} href={`itms-services://?action=download-manifest&url=${encodeURIComponent(c.manifestUrl)}`}>Install</a>
                            <a class={`wsfbtn navbtn-alt${row.isUniversal ? ' nav-universal' : ''}`} href={c.ipaUrl} download>Download</a>
                          </span>
                        </span>
                      )}
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
          {versionRows.length === 0 ? (
            iosFilter != null && (versions || []).length > 0 ? (
              <p class="applist-empty">None of the {versions.length} {versionNoun} run on iOS {iosFilter} — <a class="copies-link" href={iosFilterHref(null)}>show all</a>.</p>
            ) : (
              <p class="applist-empty">No versions in the archive yet.</p>
            )
          ) : (!showEverything && shownByDefaultCount === 0 && (
            <p class="applist-empty">Every archived version here is encrypted or no longer available — <a class="copies-link" href={everythingHref(true)}>show everything</a>.</p>
          ))}
        </div>

        {sizeChart && (
          <>
            <SectionHeader title="Bundle Size Over Time" class="size-header" />
            <div class="history-card size-chart">
              <Fragment set:html={sizeChart} />
            </div>
          </>
        )}

        {chartGroups.length > 0 && (
          <>
            <SectionHeader title="Chart History" />
            <div class="history-card">
              {chartGroups.map((g: any) => {
                const type = chartTypesById.get(g.typeId);
                const bits = [type?.name || 'Chart'];
                if (g.genreId != null) bits.push(genreNamesMap.get(g.genreId) || `Genre ${g.genreId}`);
                if (g.device === 'ipad') bits.push('iPad');
                const n = g.points.length;
                const spanStart = formatMonthYear(g.first);
                const spanEnd = formatMonthYear(g.last);
                const span = spanStart === spanEnd ? spanStart : `${spanStart} – ${spanEnd}`;
                const sp = new URLSearchParams();
                if (type && type.slug !== 'top-free') sp.set('type', type.slug);
                if (g.device === 'ipad') sp.set('device', g.device);
                if (g.genreId != null) sp.set('genre', String(g.genreId));
                if (g.peakDate) sp.set('date', g.peakDate);
                return (
                  <div class="history-row">
                    <div class="history-title">
                      <strong>{bits.join(' · ')}</strong>
                      <a class="history-link" href={`/charts?${sp.toString()}`}>View chart ›</a>
                    </div>
                    <div class="meta">
                      Peaked at #{g.peak}{g.peakDate ? ` (${formatDate(g.peakDate)})` : ''} · {n} archived {n === 1 ? 'capture' : 'captures'} · {span}
                    </div>
                    {n >= 3 && (
                      <div class="spark" title="Chart position over time — taller is higher">
                        {g.points.slice(-60).map((p: any) => (
                          <span
                            class="spark-bar"
                            style={`height:${Math.round(4 + 26 * (101 - Math.min(p.position, 100)) / 100)}px`}
                            title={`#${p.position} — ${formatDate(p.date)}`}
                          ></span>
