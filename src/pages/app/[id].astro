      font-size: 11px;
      line-height: 15px;
    }

    /* iOS-style glossy button, drawn with a CSS gradient rather than image
       slices — no seams, and autoprefixer emits the old -webkit-gradient so it
       renders on iOS 4-6. Steel-blue like the nav-bar button it replaces. */
    .navbtn {
      display: inline-block;
      position: relative;
      overflow: hidden;
      height: 29px;
      line-height: 29px;
      padding: 0 15px;
      vertical-align: middle;
      border: 1px solid #2f4c80;
      border-radius: 5px;
      background: linear-gradient(#7d97c4, #3f5f96);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
    }

    .navbtn:active {
      background: linear-gradient(#3f5f96, #7d97c4);
    }

    .navbtn-label {
      color: #fff;
      font-weight: bold;
      font-size: 14px;
      font-family: Helvetica, "Helvetica Neue", system-ui, sans-serif;
      text-shadow: 0 -1px 0 rgba(0, 0, 0, 0.45);
    }
  </style>

  <!-- Install (over-the-air) vs Download (raw .ipa): both render by default so a
       no-JS visitor gets both; the early head script tags <html> with the device
       type and these rules show only the one that works. Global because the
       .is-ios/.is-desktop class is on <html>, outside the scoped styles above. -->
  <style is:global>
    html.is-ios .navbtn-alt {
      display: none;
    }

    html.is-desktop .navbtn-install {
      display: none;
    }
  </style>

  <!-- Progressive enhancement. Deliberately old-WebKit-safe (iOS 4/5/6): no
       const/let, no arrow functions, no template strings, no classList, no
       forEach. If any of this is unsupported the script no-ops and the
       server-rendered links keep working. -->
  <script is:inline>
    (function () {
      if (!document.querySelectorAll || !document.getElementsByTagName) return;

      function hasClass(el, c) {
        return (' ' + el.className + ' ').indexOf(' ' + c + ' ') > -1;
      }
      function addClass(el, c) {
        if (!hasClass(el, c)) el.className += (el.className ? ' ' : '') + c;
      }
      function removeClass(el, c) {
        el.className = (' ' + el.className + ' ')
          .replace(' ' + c + ' ', ' ')
          .replace(/^\s+|\s+$/g, '');
      }
      function ready(fn) {
        if (document.readyState === 'complete' || document.readyState === 'interactive') fn();
        else if (document.addEventListener) document.addEventListener('DOMContentLoaded', fn, false);
        else fn();
      }

      ready(function () {
        var i;

        // 1) Global "Show everything" toggle (extra copies + hidden versions).
        var versionsRoot = document.querySelector('.versions');
        var everythingToggles = document.querySelectorAll('a.js-everything-toggle');
        for (i = 0; i < everythingToggles.length; i++) {
          (function (link) {
            link.onclick = function (e) {
              if (!versionsRoot) return true;
              if (hasClass(versionsRoot, 'show-everything')) {
                removeClass(versionsRoot, 'show-everything');
                link.innerHTML = link.getAttribute('data-expand');
              } else {
                addClass(versionsRoot, 'show-everything');
                link.innerHTML = link.getAttribute('data-collapse');
              }
              if (e && e.preventDefault) e.preventDefault();
              return false;
            };
          })(everythingToggles[i]);
        }

        // 2) "Runs on" filter: hide versions whose minimum OS is newer than the
        //    chosen (or auto-detected) major. The <select> filters in place.
        var iosSelect = document.querySelector('select.js-ios-select');
        var versionEls = document.querySelectorAll('.version');

        function applyIos(major) {
          var j, el, mm, toHide = [], shown = 0;
          for (j = 0; j < versionEls.length; j++) {
            el = versionEls[j];
            mm = parseInt(el.getAttribute('data-minos'), 10);
            if (major != null && mm > 0 && mm > major) toHide.push(el);
            else { removeClass(el, 'v-hidden-os'); shown++; }
          }
          // Never hide everything — a very old device still sees the full list.
          for (j = 0; j < toHide.length; j++) {
            if (shown === 0) removeClass(toHide[j], 'v-hidden-os');
            else addClass(toHide[j], 'v-hidden-os');
          }
        }

        var serverPicked = false;
        if (iosSelect) {
          if (iosSelect.value) serverPicked = true; // URL already chose an iOS
          iosSelect.onchange = function () {
            applyIos(iosSelect.value ? parseInt(iosSelect.value, 10) : null);
          };
        }

        // Auto-apply the device's own iOS version (set on <html> by the head
        // script), unless the URL already chose a specific one.
        var iosAttr = document.documentElement.getAttribute('data-ios');
        if (iosSelect && iosAttr && !serverPicked) {
          var maj = parseInt(iosAttr, 10);
          // Only select an option we actually offer.
          var opts = iosSelect.options, matched = null;
          for (i = 0; i < opts.length; i++) {
            var ov = parseInt(opts[i].value, 10);
            if (ov > 0 && ov >= maj && (matched === null || ov < matched)) matched = ov;
          }
          if (matched !== null) {
            iosSelect.value = String(matched);
            applyIos(matched);
          }
        }
      });
    })();
  </script>
</Layout>
