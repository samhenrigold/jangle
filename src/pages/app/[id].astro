  </div>

  <style>
    .app-header {
      margin-top: 10px;
      overflow: hidden;
    }

    .app-icon {
      position: relative;
      float: left;
      width: 72px;
      height: 72px;
      margin-right: 12px;
      background: #f3f3f3;
      border-radius: 13px;
    }

    .app-icon img {
      display: block;
      width: 72px;
      height: 72px;
      border-radius: 13px;
    }

    /* Apple's App Store icon treatment: an overlay that rounds the corners and
       adds the thin border + drop shadow. Its surround is white, so it blends
       into the white card. background-size lets the one raster serve any size. */
    .icon-mask {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: url('/icon-mask.png') no-repeat;
      background-size: 100% 100%;
    }

    .app-titles {
      overflow: hidden;
    }

    .app-name {
      margin: 0;
      font-size: 21px;
      line-height: 24px;
    }

    /* Bundle id sits inline after the title, small and baseline-aligned. */
    .app-bundle {
