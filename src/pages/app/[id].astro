                    <tr>
                      <td>{formatDate(r.captured_at)}</td>
                      <td>{r.version || '—'}</td>
                      <td>{r.rating_avg != null ? `★ ${Number(r.rating_avg).toFixed(1)}` : '—'}</td>
                      <td class="num">{r.rating_count != null ? formatNumber(r.rating_count) : '—'}</td>
                      <td class="num">{formatPrice(r.price_amount, r.price_currency) || '—'}</td>
                    </tr>
