---
import { supabaseFor } from '../../lib/supabase';
import Layout from '../../components/Layout.astro';
import DbError from '../../components/DbError.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { cacheGet, cacheSet } from '../../lib/cache';
import { setCacheHeaders, setDegraded } from '../../lib/http';
import { iconSrc } from '../../lib/icons';
import { formatDate, formatNumber } from '../../lib/format';
import {
  getChartTypes,
  getGenreNames,
  getSnapshotIndex,
  getSnapshotPositions,
  dedupeByDate,
  nearestSnapshot,
  deviceOf,
  formatPrice,
  waybackUrl,
  formatWaybackTs,
  type Device,
} from '../../lib/timemachine';
import { getOldestIcons } from '../../lib/appicons';

setCacheHeaders(Astro.response, 3600);

const url = new URL(Astro.request.url);
const supabase = supabaseFor(Astro);
let dbError = false;

const [chartTypes, snapshotIndex, genreNames] = await Promise.all([
  getChartTypes(supabase),
  getSnapshotIndex(supabase),
  getGenreNames(supabase),
]);
if (!chartTypes || !snapshotIndex || !genreNames) dbError = true;

// Only chart types that actually have archived captures appear in the nav
// ("What's Hot" exists in chart_types but has zero snapshots).
const typeSnapCount = new Map<number, number>();
for (const s of snapshotIndex || []) {
  typeSnapCount.set(s.chart_type_id, (typeSnapCount.get(s.chart_type_id) || 0) + 1);
}
const navTypes = (chartTypes || []).filter((t) => (typeSnapCount.get(Number(t.id)) || 0) > 0);

// --- Resolve filters from the query string ---------------------------------
const typeParam = url.searchParams.get('type') || 'top-free';
const chartType =
  (chartTypes || []).find((t) => t.slug === typeParam) || (chartTypes || [])[0];

const ofType = chartType
  ? (snapshotIndex || []).filter((s) => s.chart_type_id === chartType.id)
  : [];

const devicesAvailable = new Set<Device>(ofType.map((s) => deviceOf(s.source_url)));
const deviceParam = url.searchParams.get('device') === 'ipad' ? 'ipad' : 'iphone';
const device: Device = devicesAvailable.has(deviceParam)
  ? deviceParam
  : devicesAvailable.has('iphone') ? 'iphone' : 'ipad';

const ofDevice = ofType.filter((s) => deviceOf(s.source_url) === device);

// Genre options that actually have captures for this chart+device.
const genreIdsAvailable = Array.from(
  new Set(ofDevice.filter((s) => s.genre_id != null).map((s) => s.genre_id as number))
);
const genreOptions = genreIdsAvailable
  .map((id) => ({ id, name: genreNames?.get(id) || `Genre ${id}` }))
  .sort((a, b) => a.name.localeCompare(b.name));
const genreParam = url.searchParams.get('genre') || 'all';
const genreId =
  genreParam !== 'all' && genreIdsAvailable.includes(Number(genreParam))
    ? Number(genreParam)
    : null;
const genreName = genreId != null ? genreNames?.get(genreId) : null;

const dates = dedupeByDate(ofDevice.filter((s) => s.genre_id === genreId));

// Default to the oldest capture — a time machine should land in 2010, not
// last week. Any ?date= snaps to the nearest real capture. ?date=random picks
// a day server-side (the 5-min edge TTL keeps it fresh enough to feel random).
const dateParam = url.searchParams.get('date');
const snapshot =
  dateParam === 'random' && dates.length
    ? dates[Math.floor(Math.random() * dates.length)]
    : dateParam
      ? nearestSnapshot(dates, dateParam)
      : dates[0] || null;
const snapIdx = snapshot ? dates.findIndex((s) => s.id === snapshot.id) : -1;

// Year jump links: first capture date of each year present.
const firstDateOfYear = new Map<string, string>();
for (const s of dates) {
  const y = s.snapshot_date.slice(0, 4);
  if (!firstDateOfYear.has(y)) firstDateOfYear.set(y, s.snapshot_date);
}

function qs(over: Record<string, string | null | undefined>): string {
  const params: Record<string, string> = {
    type: chartType?.slug || 'top-free',
    device,
    genre: genreId != null ? String(genreId) : 'all',
    date: snapshot?.snapshot_date || '',
    ...Object.fromEntries(Object.entries(over).filter(([, v]) => v !== undefined)) as any,
  };
  const sp = new URLSearchParams();
  if (params.type && params.type !== 'top-free') sp.set('type', params.type);
  if (params.device && params.device !== 'iphone') sp.set('device', params.device);
  if (params.genre && params.genre !== 'all') sp.set('genre', params.genre);
  if (params.date) sp.set('date', params.date);
  const q = sp.toString();
  return q ? `/charts?${q}` : '/charts';
}

// --- Chart entries for the chosen capture -----------------------------------
// getSnapshotPositions owns this exact query + the tm:positions:<id> cache entry;
// don't inline a second copy that can drift from it.
let positions: any[] = [];
if (!dbError && snapshot) {
  const p = await getSnapshotPositions(supabase, snapshot.id);
  if (p === null) dbError = true;
  else positions = p;
}

// Prev/next skip over adjacent days whose chart is identical to this one (same
// ordered app_store_ids), landing on the next day the chart actually changed.
// Bounded so a long identical run doesn't fan out into many queries.
async function chartFingerprint(snapId: number): Promise<string> {
  const key = `tm:fp:${snapId}`;
  const c = cacheGet<string>(key);
  if (c != null) return c;
  const { data } = await supabase
    .from('chart_positions')
    .select('app_store_id')
    .eq('chart_snapshot_id', snapId)
    .order('position', { ascending: true })
    .limit(300);
  const fp = (data || []).map((r: any) => r.app_store_id).join(',');
  cacheSet(key, fp, 30 * 60 * 1000);
  return fp;
}
async function nextDifferentSnap(step: number): Promise<any> {
  if (dbError || snapIdx < 0) return null;
  const currentFp = positions.map((p: any) => p.app_store_id).join(',');
  const candidates: any[] = [];
  for (let idx = snapIdx + step, n = 0; n < 20 && idx >= 0 && idx < dates.length; n++, idx += step) {
    candidates.push(dates[idx]);
  }
  // The answer is almost always a capture or two away — warm the nearest few
  // fingerprints concurrently so the common case is one parallel burst, not a
  // serial walk. The loop then reads them back from cache; only a long run of
  // identical charts (rare) pays for the sequential tail.
  await Promise.all(candidates.slice(0, 6).map((s) => chartFingerprint(s.id)));
  for (const s of candidates) {
    if ((await chartFingerprint(s.id)) !== currentFp) return s;
  }
  return null;
}
// Period-authentic (oldest extracted) icons, used as a fallback when the
// archived chart artwork and the iTunes CDN icon are both missing — that's why
// some rows (e.g. Puzzloop) showed no icon in the list but did on the app page.
const loadChartIcons = async (): Promise<Map<number, string> | undefined> => {
  if (dbError || !positions.length) return undefined;
  const ids = Array.from(new Set(positions.map((p: any) => Number(p.apps?.id)).filter(Boolean)));
  return ids.length ? getOldestIcons(supabase, ids) : undefined;
};

// The two direction walks and the icon lookup are independent — one burst.
const [prevSnap, nextSnap, chartIconShas] = await Promise.all([
  nextDifferentSnap(-1),
  nextDifferentSnap(1),
  loadChartIcons(),
]);

// A transient DB failure must not render as a cacheable empty page.
if (dbError) setDegraded(Astro.response);

const snapshotDateLabel = snapshot ? formatDate(snapshot.snapshot_date) : '';
const deviceLabel = device === 'ipad' ? 'iPad' : 'iPhone';
// "Top 300 Paid Games for iPhone" — the chart depth is part of the name.
const chartCore = chartType
  ? chartType.name.startsWith('Top ') && positions.length > 0
    ? `Top ${positions.length} ${chartType.name.slice(4)}`
    : chartType.name
  : '';
const headline = chartType
  ? `${chartCore}${genreName ? ` ${genreName}` : ''} for ${deviceLabel}`
  : 'Charts';
const sourceLink = snapshot ? waybackUrl(snapshot.captured_ts, snapshot.source_url) : '';
const pageTitle = snapshot
  ? `${headline} — ${snapshotDateLabel} — Legacy Store`
  : 'Charts — Legacy Store';
---

<Layout
  title={pageTitle}
  activeTab="charts"
  bodyClass="charts-landing"
  description={`What did the App Store look like${snapshotDateLabel ? ` on ${snapshotDateLabel}` : ''}? Real historical Top Charts recovered from Apple's RSS feeds via the Wayback Machine.`}
>
    {dbError ? (
      <DbError />
    ) : (
      <>
        {/* Title + intro, per the era's apple.com/itunes/charts/ landing */}
        <h1 class="charts-title"><img src="/wsf/charts/title_charts.png" srcset="/wsf/charts/title_charts@2x.png 2x" width="211" height="29" alt="App Store Charts" /></h1>
        <p class="charts-intro">
          The real App Store Top Charts, straight from the Wayback Machine.
          Pick a chart and a day.
        </p>

        {/* Pill subnav: chart types (and device, where iPad feeds exist) */}
        <ul class="subnav">
          {navTypes.map((t) => (
            <li class={t.id === chartType?.id ? 'selected' : undefined}>
              <a href={qs({ type: t.slug, genre: 'all', date: dateParam ? snapshot?.snapshot_date : null })}>{t.name}</a>
            </li>
          ))}
          {devicesAvailable.size > 1 && (
            <>
              <li class={device === 'iphone' ? 'selected' : undefined}><a href={qs({ device: 'iphone', genre: 'all' })}>iPhone</a></li>
              <li class={device === 'ipad' ? 'selected' : undefined}><a href={qs({ device: 'ipad', genre: 'all' })}>iPad</a></li>
            </>
          )}
        </ul>

        <div class="tm-dark-controls">
          <form method="get" action="/charts" class="tm-form filters">
            {chartType && chartType.slug !== 'top-free' && <input type="hidden" name="type" value={chartType.slug} />}
            {device !== 'iphone' && <input type="hidden" name="device" value={device} />}
            {genreOptions.length > 0 && (
              <select name="genre" onchange="this.form.submit()">
                <option value="all" selected={genreId == null}>All apps</option>
                {genreOptions.map((g) => (
                  <option value={String(g.id)} selected={genreId === g.id}>{g.name}</option>
                ))}
              </select>
            )}
            <select name="date" onchange="this.form.submit()">
              {dates.map((s) => (
                <option value={s.snapshot_date} selected={snapshot?.id === s.id}>{formatDate(s.snapshot_date)}</option>
              ))}
            </select>
            <button type="submit" class="tm-go">Go</button>
          </form>

          {(firstDateOfYear.size > 1 || dates.length > 3) && (
            <div class="tm-years">
              {Array.from(firstDateOfYear.entries()).map(([year, date]) => (
                <a
                  href={qs({ date })}
                  class={snapshot && snapshot.snapshot_date.slice(0, 4) === year ? 'tm-year active' : 'tm-year'}
                >{year}</a>
              ))}
              {dates.length > 3 && <a href={qs({ date: 'random' })} class="tm-year tm-random">Random day</a>}
            </div>
          )}
        </div>

        {snapshot ? (
          <>
            <SectionHeader title={headline}>
              {sourceLink
                ? <><a class="tm-link" href={sourceLink} rel="noopener">Snapshot</a> captured {formatWaybackTs(snapshot.captured_ts) || snapshotDateLabel}</>
                : <>Snapshot from {snapshotDateLabel}</>}
            </SectionHeader>

            <ul class="chart-grid">
              {positions.map((p: any) => {
                const oldSha = p.apps?.id && chartIconShas ? chartIconShas.get(Number(p.apps.id)) : null;
                const icon = iconSrc(p.artwork_url) || (oldSha ? `/icon/${oldSha}` : '') || iconSrc(p.apps?.icon_url);
                const price = formatPrice(p.price_amount, p.price_currency);
                const inLibrary = !!p.apps;
                const href = inLibrary ? `/app/${p.apps.app_store_id || p.apps.id}` : null;
                return (
                  <li>
                    <strong>{p.position}.</strong>
                    {href
                      ? <a class="grid-art" href={href}>{icon && <img src={icon} alt="" width="100" height="100" loading="lazy" />}</a>
                      : <span class="grid-art">{icon && <img src={icon} alt="" width="100" height="100" loading="lazy" />}</span>}
                    <h3>{href ? <a href={href}>{p.display_name}</a> : p.display_name}</h3>
                    <h4>{p.developer_name}</h4>
                    {price && <span class="price">{price}</span>}
                    {href && <a href={href} class="more">View in the archive</a>}
                  </li>
                );
              })}
              {positions.length === 0 && <li class="applist-empty">This capture is empty — try another date.</li>}
            </ul>

            <div class="pagination">
              {prevSnap && <a href={qs({ date: prevSnap.snapshot_date })}>&#9664; {formatDate(prevSnap.snapshot_date)}</a>}
              <span>{snapshotDateLabel}</span>
              {nextSnap && <a href={qs({ date: nextSnap.snapshot_date })}>{formatDate(nextSnap.snapshot_date)} &#9654;</a>}
            </div>

            <a class="tm-top25" href="/most-archived">
              <span class="tm-top25-chevron">&#8250;</span>
              <span class="tm-top25-title">Top 25 Most Archived</span>
              <span class="tm-top25-sub">The apps with the most versions preserved in the archive</span>
            </a>
          </>
        ) : (
          <p class="applist-empty tm-empty">No archived captures for this chart yet.</p>
        )}
      </>
    )}

  <style>
    .tm-link {
      color: #5cc3f6 !important;
      font-weight: bold;
    }

    .tm-form {
      display: inline;
      margin: 0;
    }

    .tm-form select {
      max-width: 45%;
      -webkit-box-sizing: border-box;
      box-sizing: border-box;
    }

    .tm-go {
      padding: 3px 10px;
    }

    .tm-empty {
      display: block;
      list-style: none;
      color: #808080;
    }
  </style>
</Layout>
