---
import { supabaseFor } from '../../lib/supabase';
import Layout from '../../components/Layout.astro';
import DbError from '../../components/DbError.astro';
import Pagination from '../../components/Pagination.astro';
import SearchForm from '../../components/SearchForm.astro';
import AppList from '../../components/AppList.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { cacheGet, cacheSet } from '../../lib/cache';
import { buildPrefixTsquery, clampPage, clampPageSize } from '../../lib/search';
import { sortGenres, fetchGenresWithCounts } from '../../lib/genres';
import { getOldestIcons } from '../../lib/appicons';
import { formatNumber } from '../../lib/format';
import { setCacheHeaders, setDegraded } from '../../lib/http';

setCacheHeaders(Astro.response, 600);

const url = new URL(Astro.request.url);
const q = url.searchParams.get('q')?.trim() || '';
// Power Search "Developer Name" field. search_vector holds no developer names,
// so this is a separate lookup: match developers, then filter apps to them.
const dev = (url.searchParams.get('dev')?.trim() || '').slice(0, 80);
// Escape LIKE wildcards so a literal % or _ in the developer name matches
// itself rather than acting as a pattern. (The ilike value is parameterized by
// supabase-js, so this is about matching semantics, not SQL injection.)
const devLike = dev.replace(/[\\%_]/g, (m) => `\\${m}`);
// genre must be a positive integer or it's ignored (no injection, no junk keys).
const rawGenre = url.searchParams.get('genre');
const genreId = rawGenre && /^\d{1,7}$/.test(rawGenre) ? rawGenre : null;
// Coerce to a known sort so a junk ?sort= value can't mint a distinct cache key
// (all falling through to the same list) or silently pick the wrong branch.
const SORTS = ['versions', 'newest', 'first_date', 'name'];
const sortParam = url.searchParams.get('sort') || 'versions';
const sort = SORTS.indexOf(sortParam) >= 0 ? sortParam : 'versions';
const page = clampPage(url.searchParams.get('page'));
const pageSize = clampPageSize(url.searchParams.get('per_page'));
const offset = (page - 1) * pageSize;

const supabase = supabaseFor(Astro);
let dbError = false;

// Genres for the filter bar — independent of the search queries below, so it
// starts now and is awaited alongside them.
const genresPromise = fetchGenresWithCounts(supabase);

let searchResults: any[] = [];
let total = 0;
let totalPages = 1;
// Developers matching the "Developer Name" field, shown as their own section
// above the apps.
let matchingDevs: any[] = [];
let matchingDevTotal = 0;
// Catalog-only supplement: apps we hold a listing for but have no archived
// binary yet (version_count 0/null), surfaced in their own clearly-marked
// section below the real results. Populated on page 1 only.
let catalogOnly: any[] = [];
let catalogTotal = 0;
// Internal developer ids for the "Developer Name" branch — hoisted so the
// catalog-only lookup can reuse them.
let devIds: number[] | null = null;

// Only fetch results if the Power Search has any term (keywords, developer,
// or a category).
if (q || genreId || dev) {
  const tsquery = q ? buildPrefixTsquery(q) : null;

  // If the user typed something but it sanitized to nothing (all punctuation),
  // there is no valid tsquery to run — render the empty state instead.
  if (q && !tsquery) {
    total = 0;
    searchResults = [];
    totalPages = 1;
  } else if (dev) {
    // Developer-name branch: resolve matching developers, then filter apps to
    // them (bypasses the version-count RPCs, which don't take developer ids).
    const { data: devRows, error: devErr } = await supabase
      .from('developers')
      .select('id, artist_id, artist_name')
      .ilike('artist_name', `%${devLike}%`)
      .order('artist_name', { ascending: true })
      .limit(200);
    if (devErr) {
      console.error('developer lookup failed:', devErr.message);
      dbError = true;
    }
    // The matching developers themselves are shown first (page 1 only).
    if (page === 1) matchingDevs = (devRows || []).slice(0, 18);
    matchingDevTotal = (devRows || []).length;
    devIds = (devRows || []).map((d: any) => Number(d.id));
    if (!devIds.length) {
      total = 0;
      searchResults = [];
    } else {
      const applyFilters = (query: any) => {
        let out = query.in('developer_id', devIds);
        if (tsquery) out = out.textSearch('search_vector', tsquery);
        if (genreId) out = out.eq('genre_id', Number(genreId));
        return out;
      };
      const { count, error: cErr } = await applyFilters(
        supabase.from('apps').select('id', { count: 'exact', head: true })
      );
      if (cErr) { console.error('dev count failed:', cErr.message); dbError = true; }
      else total = count || 0;

      let listQ = applyFilters(
        supabase
          .from('apps')
          .select('id, app_store_id, bundle_id, app_store_name, developer_id, genre_id, icon_url:live_icon_url, display_name, version_count, developers!apps_developer_id_fkey(artist_name)')
      );
      if (sort === 'name') listQ = listQ.order('display_name', { ascending: true });
      else if (sort === 'first_date') listQ = listQ.order('first_version_date', { ascending: true, nullsFirst: false });
      else if (sort === 'newest') listQ = listQ.order('first_version_date', { ascending: false, nullsFirst: false });
      else listQ = listQ.order('version_count', { ascending: false });
      const { data, error: lErr } = await listQ.range(offset, offset + pageSize - 1);
      if (lErr) { console.error('dev list failed:', lErr.message); dbError = true; }
      else searchResults = (data || []).map((a: any) => ({ ...a, developer_artist_name: a.developers?.artist_name }));
    }
    totalPages = Math.max(1, Math.ceil((Number(total) || 0) / pageSize));
  } else {
    const pGenreId = genreId ? Number(genreId) : null;

    const loadCount = async () => {
      const countCacheKey = `search_count:${genreId||''}:${tsquery||''}`;
      total = cacheGet<number>(countCacheKey);
      if (typeof total === 'number') return;
      const { data: totalCountArr, error: countError } = await supabase.rpc('get_apps_count', {
        p_genre_id: pGenreId,
        p_search_query: tsquery,
      });
      total = Array.isArray(totalCountArr) ? totalCountArr[0] : totalCountArr;
      if (countError) {
        console.error('search count failed:', countError.message);
        dbError = true;
      } else {
        cacheSet(countCacheKey, Number(total) || 0, 2 * 60 * 1000);
      }
    };

    const loadList = async () => {
      const listCacheKey = `search_list:${sort}:${genreId||''}:${tsquery||''}:${page}:${pageSize}`;
      searchResults = cacheGet<any[]>(listCacheKey);
      if (searchResults) return;
      const rpcArgs = {
        p_limit: pageSize,
        p_offset: offset,
        p_genre_id: pGenreId,
        p_ascending: false,
        p_search_query: tsquery,
      };
      let listError: { message: string } | null = null;
      if (sort === 'first_date' || sort === 'newest') {
        // ascending = oldest first; descending = newest first.
        const { data, error } = await supabase.rpc('get_apps_sorted_by_first_version_date', {
          ...rpcArgs,
          p_ascending: sort === 'first_date',
        });
        listError = error;
        searchResults = data || [];
      } else if (sort === 'name') {
        let query = supabase
          .from('apps')
          .select('id, app_store_id, bundle_id, app_store_name, developer_id, genre_id, icon_url:live_icon_url, display_name, developers!apps_developer_id_fkey(artist_name)')
          .not('excluded', 'is', true)
          .order('display_name', { ascending: true })
          .range(offset, offset + pageSize - 1);
        if (tsquery) query = query.textSearch('search_vector', tsquery);
        if (genreId) query = query.eq('genre_id', Number(genreId));
        const { data, error } = await query;
        listError = error;
        searchResults = (data || []).map((a: any) => ({
          ...a,
          developer_artist_name: (a as any).developers?.artist_name,
          version_count: undefined,
        }));
      } else {
        const { data, error } = await supabase.rpc('get_apps_sorted_by_version_count', rpcArgs);
        listError = error;
        searchResults = data || [];
      }
      if (listError) {
        console.error(`search sort=${sort} failed:`, listError.message);
        dbError = true;
      } else {
        cacheSet(listCacheKey, searchResults, 60 * 1000);
      }
    };

    // Count and page are independent — one round trip of latency, not two.
    await Promise.all([loadCount(), loadList()]);
    totalPages = Math.max(1, Math.ceil((Number(total) || 0) / pageSize));
  }

  // Catalog-only matches (metadata, no archived binary). Page 1 only — this is a
  // supplement to the paginated results, not itself paged. Same filters as the
  // main search; the dev branch scopes it to the matched developers. Skipped
  // when the query sanitized to nothing. Best-effort: a failure here leaves the
  // section empty and never taints the real results or sets dbError.
  if (page === 1 && !(q && !tsquery)) {
    let cq: any = supabase
      .from('apps')
      .select('id, app_store_id, bundle_id, app_store_name, display_name, developer_id, genre_id, icon_url:live_icon_url, developers!apps_developer_id_fkey(artist_name)', { count: 'exact' })
      .not('excluded', 'is', true)
      .or('version_count.is.null,version_count.eq.0')
      .order('app_store_name', { ascending: true, nullsFirst: false })
      .limit(30);
    if (tsquery) cq = cq.textSearch('search_vector', tsquery);
    if (genreId) cq = cq.eq('genre_id', Number(genreId));
    // Developer-name branch: only apps by the matched developers (none → empty).
    if (dev) cq = (devIds && devIds.length) ? cq.in('developer_id', devIds) : null;
    if (cq) {
      const { data, count, error } = await cq;
      if (error) console.error('catalog-only lookup failed:', error.message);
      else {
        catalogOnly = (data || []).map((a: any) => ({ ...a, developer_artist_name: a.developers?.artist_name }));
        catalogTotal = count || 0;
      }
    }
  }
}

const { genres, error: genresError } = await genresPromise;
if (genresError) dbError = true;

// Group Game subgenres after the parent Games genre (returns a copy)
const sortedGenres = sortGenres(genres);

// Period-authentic (oldest extracted) icons for the results — same source the
// rest of the site uses, so search rows aren't stuck on the (often-dead) CDN url.
let iconShas: Map<number, string> | undefined;
if (!dbError && searchResults.length) {
  iconShas = await getOldestIcons(supabase, searchResults.map((a: any) => Number(a.id)).filter(Boolean));
}

// A transient DB failure must not render as a cacheable "no results" page.
if (dbError) setDegraded(Astro.response);

const genreName = genreId ? (sortedGenres.find((g: any) => String(g.id) === String(genreId))?.genre_name ?? null) : null;
const hasQuery = !!(q || genreId || dev);
const resultLabel = dev && q ? `“${q}” by ${dev}`
  : dev ? `Apps by ${dev}`
  : q ? `Results for “${q}”`
  : `${genreName || 'Genre'} apps`;
const pageTitle = q ? `“${q}” — Search — Legacy Store`
  : dev ? `${dev} — Search — Legacy Store`
  : 'Search — Legacy Store';

function pageHref(p: number) {
  const sp = new URLSearchParams();
  if (q) sp.set('q', q);
  if (dev) sp.set('dev', dev);
  if (genreId) sp.set('genre', String(genreId));
  if (sort !== 'versions') sp.set('sort', sort);
  if (p !== 1) sp.set('page', String(p));
  if (pageSize !== 20) sp.set('per_page', String(pageSize));
  const s = sp.toString();
  return s ? `/search?${s}` : '/search';
}
---

<Layout title={pageTitle} activeTab="search" searchQuery={q} bodyClass="search-page" description="Search Legacy Store — archived versions of classic iPhone and iPad apps, by name, developer, or category.">
  <div class="content">
    {dbError ? (
      <DbError message="The archive is having trouble searching right now. Please try again in a minute." />
    ) : (
      <>
        <SearchForm q={q} dev={dev} genreId={genreId} sort={sort} genres={sortedGenres} />

        {hasQuery && (
          <>
            {/* Developer-name search surfaces the matching developers first. */}
            {matchingDevs.length > 0 && (
              <>
                <SectionHeader
                  title={`Developers matching “${dev}”`}
                  level={1}
                  detail={matchingDevTotal > matchingDevs.length ? `${matchingDevs.length} of ${formatNumber(matchingDevTotal)}` : undefined}
                />
                <ul class="dev-matches">
                  {matchingDevs.map((d: any) => (
                    <li><a href={`/developer/${d.artist_id ?? d.id}`}>{d.artist_name}</a></li>
                  ))}
                </ul>
              </>
            )}

            {searchResults.length > 0 ? (
              <>
                <SectionHeader
                  title={dev ? `Apps${matchingDevs.length ? ' by these developers' : ` by ${dev}`}` : resultLabel}
                  level={matchingDevs.length ? 2 : 1}
                  detail={Number(total) > 0 ? `${formatNumber(total)} found` : undefined}
                />
                <AppList list={searchResults} iconShas={iconShas} />
                {totalPages > 1 && <Pagination page={page} totalPages={totalPages} hrefFor={pageHref} />}
              </>
            ) : (matchingDevs.length === 0 && catalogOnly.length === 0) ? (
              <div class="no-results">
                <p>{dev ? `No developer matches “${dev}”.` : q ? `No apps matched “${q}”.` : 'No apps in this genre yet.'}</p>
                {q && <p>Search matches the beginnings of words — try a shorter prefix, a different word, or check the spelling.</p>}
              </div>
            ) : null}

            {/* Catalog-only: we hold a store listing for these but have no
                archived binary to download (yet). Kept visually distinct from
                the real, installable results above. */}
            {catalogOnly.length > 0 && (
              <div class="catalog-only">
                <SectionHeader
                  title="Also in the catalog — no binaries archived yet"
                  level={searchResults.length || matchingDevs.length ? 2 : 1}
                  detail={catalogTotal > catalogOnly.length ? `${catalogOnly.length} of ${formatNumber(catalogTotal)}` : (catalogTotal ? `${formatNumber(catalogTotal)} found` : undefined)}
                />
                <p class="catalog-note">We have a store listing for {catalogTotal === 1 ? 'this app' : 'these apps'}, but no archived copy to install or download yet — metadata only.</p>
                <AppList list={catalogOnly} />
              </div>
            )}
          </>
        )}
      </>
    )}
  </div>

  <style>
    /* Power Search panel styling lives in SearchForm.astro (Astro scopes
       styles to the component that owns the markup). */

    /* Matching-developers section: a compact wrapping list of name links. */
    .dev-matches {
      list-style: none;
      margin: 0 0 20px 0;
      padding: 0;
      overflow: hidden;
    }

    .dev-matches li {
      float: left;
      width: 33.333%;
      padding: 5px 12px 5px 0;
      -webkit-box-sizing: border-box;
      box-sizing: border-box;
    }

    .dev-matches li a {
      display: block;
      font-size: 13px;
      font-weight: bold;
      color: #298cda;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .no-results {
      text-align: center;
      padding: 34px 20px;
      color: #767676;
    }

    /* Catalog-only section: visually secondary to the installable results —
       a hairline rule above it and slightly muted icons so it reads as "records
       we know about" rather than "apps you can get". */
    .catalog-only {
      margin-top: 22px;
      padding-top: 4px;
      border-top: 1px solid #e2e2e2;
    }

    .catalog-note {
      margin: -2px 2px 10px;
      font-size: 11px;
      color: #898989;
    }

    .catalog-only :global(.applist .icon) {
      opacity: 0.72;
    }

    @media screen and (max-width: 767px) {
      .dev-matches li { width: 50%; }
    }
  </style>
</Layout>
