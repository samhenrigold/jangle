---
import { getSupabaseClient } from '../../lib/supabase';
import SearchLayout from '../../components/SearchLayout.astro';
import SearchForm from '../../components/SearchForm.astro';
import AppList from '../../components/AppList.astro';
import { cacheGet, cacheSet } from '../../lib/cache';

// Search parameters
const url = new URL(Astro.request.url);
const q = url.searchParams.get('q')?.trim() || '';
const genreId = url.searchParams.get('genre');
const sort = url.searchParams.get('sort') || 'versions';
const page = Number(url.searchParams.get('page') || '1');
const pageSize = Math.min(50, Number(url.searchParams.get('per_page') || '20'));
const offset = (page - 1) * pageSize;

const supabase = getSupabaseClient((Astro.locals as any)?.runtime?.env);

// Fetch genres for the search form
const genresCacheKey = 'genres_with_counts';
let genres = cacheGet<any[]>(genresCacheKey);
if (!genres) {
  const { data } = await supabase.rpc('get_genres_with_counts');
  genres = data || [];
  cacheSet(genresCacheKey, genres, 10 * 60 * 1000);
}

// Group Game subgenres after the parent Games genre
const sortedGenres = genres.sort((a: any, b: any) => {
  if (a.id === 6014) return -1;
  if (b.id === 6014) return 1;
  
  if (a.genre_id && String(a.genre_id).startsWith('70')) {
    if (b.genre_id && String(b.genre_id).startsWith('70')) {
      return a.genre_name.localeCompare(b.genre_name);
    }
    return -1;
  }
  
  if (b.genre_id && String(b.genre_id).startsWith('70')) {
    return 1;
  }
  
  return a.genre_name.localeCompare(b.genre_name);
});

let searchResults: any[] = [];
let total = 0;
let totalPages = 1;

// Only fetch search results if there's a search query or genre filter
if (q || genreId) {
  const countArgs: Record<string, any> = {
    p_genre_id: genreId ? Number(genreId) : null,
    p_search_query: q ? q.split(/\s+/).map((t) => `${t}:*`).join(' & ') : null,
  };
  
  const countCacheKey = `search_count:${genreId||''}:${q}`;
  total = cacheGet<number>(countCacheKey);
  if (typeof total !== 'number') {
    const { data: totalCountArr } = await supabase.rpc('get_apps_count', countArgs);
    total = Array.isArray(totalCountArr) ? totalCountArr[0] : totalCountArr;
    cacheSet(countCacheKey, Number(total) || 0, 2 * 60 * 1000);
  }

  const rpcArgs = {
    p_limit: pageSize,
    p_offset: offset,
    p_genre_id: countArgs.p_genre_id,
    p_ascending: false,
    p_search_query: countArgs.p_search_query,
  };

  const listCacheKey = `search_list:${sort}:${genreId||''}:${q}:${page}:${pageSize}`;
  searchResults = cacheGet<any[]>(listCacheKey);
  if (!searchResults) {
    if (sort === 'first_date') {
      const { data } = await supabase.rpc('get_apps_sorted_by_first_version_date', rpcArgs);
      searchResults = data || [];
    } else if (sort === 'name') {
      const { data } = await supabase
        .from('apps')
        .select('id, app_store_id, bundle_id, app_store_name, developer_id, genre_id, icon_url, display_name, executable_name, developers!apps_developer_id_fkey(artist_name)')
        .order('display_name', { ascending: true })
        .range(offset, offset + pageSize - 1);
      searchResults = (data || []).map((a: any) => ({
        ...a,
        developer_artist_name: (a as any).developers?.artist_name,
        version_count: undefined,
      }));
    } else {
      const { data } = await supabase.rpc('get_apps_sorted_by_version_count', rpcArgs);
      searchResults = data || [];
    }
    cacheSet(listCacheKey, searchResults, 60 * 1000);
  }
  
  totalPages = Math.max(1, Math.ceil((Number(total) || 0) / pageSize));
}
---

<SearchLayout title="Search — Jangle" searchQuery={q}>
  <div class="content">
    <div class="search-form-section">
      <SearchForm q={q} genreId={genreId} sort={sort} genres={sortedGenres} />
      {total > 0 && <div class="total">Total results: {total}</div>}
    </div>
    
    {!q && !genreId ? (
      <div class="search-intro">
        <h2>Find Apps</h2>
        <p>Use the search form to find apps by name, bundle ID, or developer. You can also filter by genre and sort results.</p>
      </div>
    ) : (
      <>
        {searchResults.length > 0 ? (
          <>
            <AppList list={searchResults} />
            {totalPages > 1 && (
              <div class="pagination">
                {page > 1 && (
                  <a href={`/search?q=${encodeURIComponent(q)}&genre=${genreId||''}&sort=${sort}&page=${page-1}&per_page=${pageSize}`}>Prev</a>
                )}
                <span>Page {page} / {totalPages}</span>
                {page < totalPages && (
                  <a href={`/search?q=${encodeURIComponent(q)}&genre=${genreId||''}&sort=${sort}&page=${page+1}&per_page=${pageSize}`}>Next</a>
                )}
              </div>
            )}
          </>
        ) : (
          <div class="no-results">
            <p>No apps found matching your search criteria.</p>
            <p>Try adjusting your search terms or genre filter.</p>
          </div>
        )}
      </>
    )}
  </div>

  <style>
    .content { 
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }
    
    .search-form-section {
      margin-bottom: 20px;
      padding: 20px;
      background: #f8f8f8;
      border-radius: 8px;
    }
    
    .total { 
      margin-top: 10px; 
      color: #666; 
      font-size: 13px; 
    }
    
    .search-intro {
      text-align: center;
      padding: 40px 20px;
      color: #666;
    }
    
    .search-intro h2 {
      color: #333;
      margin-bottom: 16px;
    }
    
    .no-results {
      text-align: center;
      padding: 40px 20px;
      color: #666;
    }
    
    .pagination { 
      margin-top: 20px; 
      text-align: center;
    }
    
    .pagination a { 
      margin: 0 8px;
      padding: 8px 16px;
      text-decoration: none;
      color: #007AFF;
      border: 1px solid #007AFF;
      border-radius: 4px;
      transition: all 0.2s ease;
    }
    
    .pagination a:hover {
      background-color: #007AFF;
      color: white;
    }
    
    .pagination span {
      margin: 0 16px;
      color: #666;
    }
  </style>
</SearchLayout>
