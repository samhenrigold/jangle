---
import { getSupabaseClient } from '../../lib/supabase';
import Layout from '../../components/Layout.astro';
import AppList from '../../components/AppList.astro';
import { cacheGet, cacheSet } from '../../lib/cache';
import { clampPage, clampPageSize } from '../../lib/search';
import { formatNumber } from '../../lib/format';
import { setCacheHeaders, setDegraded } from '../../lib/http';

const { genreId } = Astro.params;
const url = new URL(Astro.request.url);
const page = clampPage(url.searchParams.get('page'));
const pageSize = clampPageSize(url.searchParams.get('per_page'), 25);
const offset = (page - 1) * pageSize;

const supabase = getSupabaseClient((Astro.locals as any)?.runtime?.env);
let dbError = false;

// Fetch genre details. maybeSingle distinguishes "no such genre" (404) from a
// transient DB failure (503, uncacheable) — a blip must not become a cached 404.
const genreCacheKey = `genre:${genreId}`;
let genre = cacheGet<any>(genreCacheKey);
if (!genre) {
  const { data, error } = await supabase
    .from('genres')
    .select('*')
    .eq('id', genreId)
    .maybeSingle();
  if (error) {
    console.error('genre fetch failed:', error.message);
    dbError = true;
  }
  genre = data;
  if (genre) {
    cacheSet(genreCacheKey, genre, 10 * 60 * 1000);
  }
}

if (!genre && !dbError) {
  return Astro.rewrite('/404');
}

setCacheHeaders(Astro.response, 3600);

// Fetch apps in this genre
const countArgs = { p_genre_id: Number(genreId), p_search_query: null };
const countCacheKey = `genre_count:${genreId}`;
let total = cacheGet<number>(countCacheKey);
if (!dbError && typeof total !== 'number') {
  const { data: totalCountArr, error } = await supabase.rpc('get_apps_count', countArgs);
  total = Array.isArray(totalCountArr) ? totalCountArr[0] : totalCountArr;
  if (error) {
    console.error('genre count failed:', error.message);
    dbError = true;
  } else {
    cacheSet(countCacheKey, Number(total) || 0, 5 * 60 * 1000);
  }
}

const rpcArgs = {
  p_limit: pageSize,
  p_offset: offset,
  p_genre_id: Number(genreId),
  p_ascending: false,
  p_search_query: null,
};

const listCacheKey = `genre_apps:${genreId}:${page}:${pageSize}`;
let list = cacheGet<any[]>(listCacheKey);
if (!dbError && !list) {
  const { data, error } = await supabase.rpc('get_apps_sorted_by_version_count', rpcArgs);
  list = data || [];
  if (error) {
    console.error('genre list failed:', error.message);
    dbError = true;
  } else {
    cacheSet(listCacheKey, list, 5 * 60 * 1000);
  }
}

const totalPages = Math.max(1, Math.ceil((Number(total) || 0) / pageSize));

// A transient DB failure must not render as a cacheable empty page.
if (dbError) setDegraded(Astro.response);

const genreName = genre?.genre_name || 'Category';
---

<Layout title={`${genreName} — Legacy Store`} activeTab="categories" description={`Top ${genreName} apps on Legacy Store — archived versions of classic iPhone and iPad apps, installable on old iOS devices.`}>
  <div class="content">
    {dbError ? (
      <p class="db-error">The archive is having trouble loading right now. Please try again in a minute.</p>
    ) : (
      <>
        <div class="section-header">
          <h1 class="section-title">{genreName}</h1>
          {typeof total === 'number' && total > 0 && <span class="section-detail">{formatNumber(total)} apps</span>}
        </div>
        <AppList list={list} startRank={offset + 1} />

        {totalPages > 1 && (
          <div class="pagination">
            {page > 1 && (
              <a href={`/categories/${genreId}?page=${page-1}${pageSize !== 25 ? `&per_page=${pageSize}` : ''}`}>&#9664; Previous</a>
            )}
            <span>Page {page} of {totalPages}</span>
            {page < totalPages && (
              <a href={`/categories/${genreId}?page=${page+1}${pageSize !== 25 ? `&per_page=${pageSize}` : ''}`}>Next {pageSize} &#9654;</a>
            )}
          </div>
        )}
      </>
    )}
  </div>
</Layout>
