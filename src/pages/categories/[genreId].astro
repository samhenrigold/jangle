---
import { supabaseFor } from '../../lib/supabase';
import Layout from '../../components/Layout.astro';
import DbError from '../../components/DbError.astro';
import Pagination from '../../components/Pagination.astro';
import AppList from '../../components/AppList.astro';
import { cacheGet, cacheSet } from '../../lib/cache';
import { clampPage, clampPageSize } from '../../lib/search';
import { formatNumber } from '../../lib/format';
import { setCacheHeaders, setDegraded } from '../../lib/http';
import { getChartTypes, getSnapshotIndex, deviceOf } from '../../lib/timemachine';
import { getOldestIcons } from '../../lib/appicons';

const { genreId } = Astro.params;
const url = new URL(Astro.request.url);
const page = clampPage(url.searchParams.get('page'));
const pageSize = clampPageSize(url.searchParams.get('per_page'), 25);
const offset = (page - 1) * pageSize;

const supabase = supabaseFor(Astro);
let dbError = false;

// Fetch genre details. maybeSingle distinguishes "no such genre" (404) from a
// transient DB failure (503, uncacheable) — a blip must not become a cached 404.
const genreCacheKey = `genre:${genreId}`;
let genre = cacheGet<any>(genreCacheKey);
if (!genre) {
  const { data, error } = await supabase
    .from('genres')
    .select('id, genre_id, genre_name')
    .eq('id', genreId)
    .maybeSingle();
  if (error) {
    console.error('genre fetch failed:', error.message);
    dbError = true;
  }
  genre = data;
  if (genre) {
    cacheSet(genreCacheKey, genre, 10 * 60 * 1000);
  }
}

if (!genre && !dbError) {
  return Astro.rewrite('/404');
}

setCacheHeaders(Astro.response, 3600);

// Fetch apps in this genre
const countArgs = { p_genre_id: Number(genreId), p_search_query: null };
const countCacheKey = `genre_count:${genreId}`;
let total = cacheGet<number>(countCacheKey);
if (!dbError && typeof total !== 'number') {
  const { data: totalCountArr, error } = await supabase.rpc('get_apps_count', countArgs);
  total = Array.isArray(totalCountArr) ? totalCountArr[0] : totalCountArr;
  if (error) {
    console.error('genre count failed:', error.message);
    dbError = true;
  } else {
    cacheSet(countCacheKey, Number(total) || 0, 5 * 60 * 1000);
  }
}

const rpcArgs = {
  p_limit: pageSize,
  p_offset: offset,
  p_genre_id: Number(genreId),
  p_ascending: false,
  p_search_query: null,
};

const listCacheKey = `genre_apps:${genreId}:${page}:${pageSize}`;
let list = cacheGet<any[]>(listCacheKey);
if (!dbError && !list) {
  const { data, error } = await supabase.rpc('get_apps_sorted_by_version_count', rpcArgs);
  list = data || [];
  if (error) {
    console.error('genre list failed:', error.message);
    dbError = true;
  } else {
    cacheSet(listCacheKey, list, 5 * 60 * 1000);
  }
}

const totalPages = Math.max(1, Math.ceil((Number(total) || 0) / pageSize));

// Period-authentic (oldest) icons for the list.
let iconShas: Map<number, string> | undefined;
if (!dbError && (list || []).length) {
  iconShas = await getOldestIcons(supabase, (list || []).map((a: any) => Number(a.id)));
}

// Time Machine module: archived chart captures exist for ~30 genres
// (chart_snapshots.genre_id = genres.id). One row per chart type with the
// years we can show.
type GenreChartRow = { slug: string; name: string; years: { year: string; date: string }[] };
// Decorative teaser — a failure here drops the module, never 503s the category.
let genreCharts: GenreChartRow[] = [];
if (!dbError) {
  const [types, index] = await Promise.all([getChartTypes(supabase), getSnapshotIndex(supabase)]);
  if (types && index) {
    for (const t of types) {
      // iPhone feeds only — the genre module is a teaser, not a full browser.
      const snaps = index.filter(
        (s) => s.genre_id === Number(genreId) && s.chart_type_id === Number(t.id) && deviceOf(s.source_url) === 'iphone'
      );
      if (!snaps.length) continue;
      const firstOfYear = new Map<string, string>();
      for (const s of snaps) {
        const y = s.snapshot_date.slice(0, 4);
        if (!firstOfYear.has(y)) firstOfYear.set(y, s.snapshot_date);
      }
      genreCharts.push({
        slug: t.slug,
        name: t.name,
        years: Array.from(firstOfYear.entries()).map(([year, date]) => ({ year, date })),
      });
    }
  }
}

// A transient DB failure must not render as a cacheable empty page.
if (dbError) setDegraded(Astro.response);

const genreName = genre?.genre_name || 'Category';
---

<Layout title={`${genreName} — Legacy Store`} activeTab="categories" description={`Top ${genreName} apps on Legacy Store — archived versions of classic iPhone and iPad apps, installable on old iOS devices.`}>
  <div class="content">
    {dbError ? (
      <DbError />
    ) : (
      <>
        <div class="section-header">
          <h1 class="section-title">{genreName}</h1>
          {typeof total === 'number' && total > 0 && <span class="section-detail">{formatNumber(total)} apps</span>}
        </div>
        <AppList list={list} startRank={offset + 1} iconShas={iconShas} />

        {totalPages > 1 && <Pagination page={page} totalPages={totalPages} hrefFor={(p) => `/categories/${genreId}?page=${p}${pageSize !== 25 ? `&per_page=${pageSize}` : ''}`} nextLabel={`Next ${pageSize}`} />}

        {genreCharts.length > 0 && (
          <>
            <div class="section-header">
              <h2 class="section-title">Charts</h2>
              <span class="section-detail">archived {genreName} charts</span>
            </div>
            <div class="genre-charts">
              {genreCharts.map((row) => (
                <div class="genre-chart-row">
                  <span class="genre-chart-name">{row.name}</span>
                  <span class="genre-chart-years">
                    {row.years.map((y) => (
                      <a class="genre-chart-year" href={`/charts?${row.slug !== 'top-free' ? `type=${row.slug}&` : ''}genre=${genreId}&date=${y.date}`}>{y.year}</a>
                    ))}
                  </span>
                </div>
              ))}
            </div>
            <p class="genre-chart-note">Real {genreName} Top Charts from Apple's RSS feeds, archived by the Wayback Machine.</p>
          </>
        )}
      </>
    )}
  </div>

  <style>
    .genre-charts {
      border: 1px solid #e1e1e1;
      border-radius: 8px;
      background: #fff;
      overflow: hidden;
    }

    .genre-chart-row {
      border-bottom: 1px solid #e1e1e1;
      padding: 8px 10px;
      overflow: hidden;
    }

    .genre-chart-row:last-child {
      border-bottom: none;
    }

    .genre-chart-name {
      float: left;
      width: 110px;
      font-size: 14px;
      font-weight: bold;
      line-height: 22px;
    }

    .genre-chart-years {
      display: block;
      overflow: hidden;
    }

    .genre-chart-year {
      display: inline-block;
      padding: 2px 7px;
      margin: 1px 2px 1px 0;
      color: #385487;
      font-size: 13px;
      font-weight: bold;
      border: 1px solid #c8d0dc;
      border-radius: 6px;
      background: #f7f7f8;
    }

    .genre-chart-year:active {
      background: #e8ebef;
    }

    .genre-chart-note {
      margin: 6px 4px 0 4px;
      color: #8e8e93;
      font-size: 11px;
      line-height: 15px;
    }
  </style>
</Layout>
