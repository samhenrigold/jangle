---
import { supabaseFor } from '../../lib/supabase';
import Layout from '../../components/Layout.astro';
import DbError from '../../components/DbError.astro';
import { sortGenres, fetchGenresWithCounts, isGameSubgenre } from '../../lib/genres';
import { formatNumber } from '../../lib/format';
import { setCacheHeaders, setDegraded } from '../../lib/http';
import { iconSrc } from '../../lib/icons';
import { getOldestIcons } from '../../lib/appicons';

setCacheHeaders(Astro.response, 86400);

const supabase = supabaseFor(Astro);
let dbError = false;

// Row icons: the most-preserved app in each genre, using its period-authentic
// (oldest) extracted icon where we have one, else the iTunes CDN icon.
// Decorative, and independent of the genre list — the chains run concurrently.
const genreIcon = new Map<number, string>();
const loadGenreIcons = async () => {
  const { data: tops, error } = await supabase.rpc('get_genre_top_apps');
  if (error || !tops) return;
  const iconShas = await getOldestIcons(supabase, tops.map((t: any) => Number(t.app_id)));
  for (const t of tops) {
    const sha = iconShas?.get(Number(t.app_id));
    const src = sha ? `/icon/${sha}` : iconSrc(t.icon_url);
    if (src) genreIcon.set(Number(t.genre_id), src);
  }
};

const [{ genres, error: genresError }] = await Promise.all([
  fetchGenresWithCounts(supabase),
  loadGenreIcons(),
]);
if (genresError) dbError = true;

// The App Store game subgenres (genre_id 70xx) are populated only where an app's
// PRIMARY genre happens to be the subgenre — a tiny, misleading fraction of the
// ~10k games — so hide them here; the top-level genres are the real index.
const topLevelGenres = sortGenres(genres ?? []).filter((g: any) => !isGameSubgenre(g));

// A transient DB failure must not render as a cacheable empty page.
if (dbError) setDegraded(Astro.response);
---

<Layout title="Categories — Legacy Store" activeTab="categories" description="Browse classic iPhone and iPad apps by category — games, entertainment, utilities, and more, archived for old iOS devices.">
  <div class="content">
    {dbError ? (
      <DbError />
    ) : (
      <ul class="cat-list">
        {topLevelGenres.map((genre: any) => (
          <li class="cat">
            <a href={`/categories/${genre.id}`} class="cat-link">
              <span class="chevron">&#8250;</span>
              <span class="cat-count">{formatNumber(genre.app_count)}</span>
              <span class="cat-icon">{genreIcon.get(Number(genre.id)) ? <><img src={genreIcon.get(Number(genre.id))} alt="" width="40" height="40" loading="lazy" /><span class="icon-mask"></span></> : null}</span>
              <span class="cat-name">{genre.genre_name}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>

  <style>
    /* Category rows in the era's blue listing panel */
    .cat-list {
      list-style: none;
      margin: 10px 0 20px 0;
      padding: 0;
      overflow: hidden;
    }

    .cat {
      border-bottom: 1px solid #ececec;
    }

    .cat:last-child {
      border-bottom: none;
    }

    .cat-link {
      display: block;
      padding: 7px 2px;
      min-height: 40px;
      text-decoration: none;
    }

    .cat-link:hover {
      text-decoration: none;
      background-color: #eaf3f8;
    }

    /* Genre row icon (top app in the genre), gloss mask applied. */
    .cat-icon {
      position: relative;
      float: left;
      width: 40px;
      height: 40px;
      margin-right: 12px;
      background: transparent url('/icon-placeholder.png') no-repeat;
      background-size: 100% 100%;
    }

    .cat-icon img {
      display: block;
      width: 40px;
      height: 40px;
    }

    .cat-icon .icon-mask {
      left: 0;
      width: 100%;
      height: 100%;
      background-size: 100% 100%;
    }

    .cat-name {
      display: block;
      overflow: hidden;
      font-size: 13px;
      font-weight: bold;
      color: #298cda;
      line-height: 40px;
    }

    .cat-count {
      float: right;
      margin: 0 4px 0 10px;
      color: #898989;
      font-size: 11px;
      line-height: 40px;
    }

    .chevron {
      display: none;
    }
  </style>
</Layout>
