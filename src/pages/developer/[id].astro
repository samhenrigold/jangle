---
import { supabaseFor } from '../../lib/supabase';
import Layout from '../../components/Layout.astro';
import DbError from '../../components/DbError.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { cacheGet, cacheSet } from '../../lib/cache';
import { formatNumber } from '../../lib/format';
import { setCacheHeaders, setDegraded } from '../../lib/http';
import { getOldestIcons } from '../../lib/appicons';
import { iconSrc, appIconSrc } from '../../lib/icons';
import { appTitleOf } from '../../lib/apps';

const { id } = Astro.params;
const supabase = supabaseFor(Astro);
const rawParam = id as string;
let dbError = false;

// Resolve a /developer/<param> URL. The public, canonical id is Apple's
// artist_id (the same number apps.apple.com/.../developer/idNNN uses); we prefer
// it and fall back to our internal developers.id so old internal-id links keep
// working. artist_id is int4, so an out-of-range param can't be one — skip it
// rather than trip a bigint→int overflow. (A handful of low internal ids
// coincide with some artist_id; artist_id-first is the canonical choice and
// mirrors how /app resolves app_store_id before the internal id.)
const devCacheKey = `developer:${rawParam}`;
let developer = cacheGet<any>(devCacheKey);
if (!developer) {
  const attempts: { col: string; value: string }[] = [];
  if (/^\d+$/.test(rawParam)) {
    if (rawParam !== '0' && Number(rawParam) <= 2147483647) attempts.push({ col: 'artist_id', value: rawParam });
    attempts.push({ col: 'id', value: rawParam });
  }
  for (const { col, value } of attempts) {
    // maybeSingle separates "no such developer" (404) from a transient DB
    // failure (503, uncacheable). Break ties by lowest id for determinism.
    const { data, error } = await supabase
      .from('developers')
      .select('id, artist_id, artist_name')
      .eq(col, value)
      .order('id', { ascending: true })
      .limit(1)
      .maybeSingle();
    if (error) {
      console.error('developer fetch failed:', error.message);
      dbError = true;
      break;
    }
    if (data) { developer = data; break; }
  }
  if (developer) cacheSet(devCacheKey, developer, 30 * 60 * 1000);
}

if (!developer && !dbError) {
  return Astro.rewrite('/404');
}

// Alias → canonical: a bundle-id/internal-id URL 301s to the artist_id URL so
// links consolidate on the real Apple developer id. The canonical URL itself
// never redirects. Cacheable so the edge serves the hop without re-resolving.
if (developer?.artist_id != null) {
  const canonical = String(developer.artist_id);
  if (rawParam !== canonical) {
    return new Response(null, {
      status: 301,
      headers: { Location: `/developer/${canonical}${Astro.url.search}`, 'Cache-Control': 'public, max-age=3600, s-maxage=86400' },
    });
  }
}

setCacheHeaders(Astro.response, 3600);

// All apps by this developer, most-preserved first. Keyed by the internal id so
// the artist_id and internal-id URLs share one cache entry.
const listCacheKey = `developer_apps:${developer.id}`;
let list = cacheGet<any[]>(listCacheKey);
if (!dbError && !list) {
  const { data, error } = await supabase
    .from('apps')
    .select('id, app_store_id, app_store_name, display_name, bundle_id, icon_url:live_icon_url, version_count')
    .eq('developer_id', developer.id)
    .not('excluded', 'is', true)
    .order('version_count', { ascending: false })
    .order('app_store_name', { ascending: true })
    .limit(300);
  list = data || [];
  if (error) {
    console.error('developer apps failed:', error.message);
    dbError = true;
  } else {
    cacheSet(listCacheKey, list, 10 * 60 * 1000);
  }
}

// Period-authentic (oldest) icons for the list.
let iconShas: Map<number, string> | undefined;
if (!dbError && (list || []).length) {
  iconShas = await getOldestIcons(supabase, (list || []).map((a: any) => Number(a.id)));
}

if (dbError) setDegraded(Astro.response);

const developerName = developer?.artist_name || 'Developer';
const appCount = (list || []).length;
const appNoun = appCount === 1 ? 'app' : 'apps';
---

<Layout
  title={`${developerName} — Legacy Store`}
  activeTab="none"
  description={`Apps by ${developerName} on Legacy Store — archived versions of classic iPhone and iPad apps, installable on old iOS devices.`}
>
  <div class="content">
    {dbError ? (
      <DbError />
    ) : (
      <>
        <SectionHeader
          title={developerName}
          level={1}
          detail={appCount > 0 ? `${formatNumber(appCount)} ${appNoun} in the archive` : undefined}
        />
        {appCount > 0 ? (
          <ul class="app-grid">
            {(list || []).map((a: any) => {
              const sha = iconShas && a.id != null ? iconShas.get(Number(a.id)) : null;
              const icon = appIconSrc(sha, a.icon_url);
              const href = `/app/${a.app_store_id ? a.app_store_id : a.id}`;
              const vc = a.version_count == null ? null : Number(a.version_count);
              return (
                <li>
                  <a class="grid-icon" href={href}>{icon ? <><img src={icon} alt="" width="100" height="100" loading="lazy" decoding="async" /><span class="grid-mask"></span></> : null}</a>
                  <a class="grid-name" href={href}>{appTitleOf(a)}</a>
                  {vc != null && vc > 0 && <span class="grid-sub">{vc} {vc === 1 ? 'version' : 'versions'}</span>}
                </li>
              );
            })}
          </ul>
        ) : (
          <p class="applist-empty">No apps in the archive for this developer yet.</p>
        )}
      </>
    )}
  </div>
</Layout>
