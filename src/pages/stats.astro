---
import Layout from '../components/Layout.astro';
import { supabaseFor } from '../lib/supabase';
import { setCacheHeaders, setDegraded } from '../lib/http';
import { formatNumber, formatDate, formatFileSize } from '../lib/format';
import { iconSrc, appIconSrc } from '../lib/icons';
import { osShortLabel } from '../lib/devices';
import { barChartSVG, type BarDatum } from '../lib/charts';

// On localhost (astro dev) we want live, uncached numbers so changes to the DB
// show up immediately; in production the numbers regenerate daily (a pg_cron job
// refreshes the cache the RPC reads, and the edge TTL picks that up), so a
// visitor sees at-most-a-day-old data.
const isDev = import.meta.env.DEV;
if (isDev) {
  Astro.response.headers.set('Cache-Control', 'no-store');
} else {
  setCacheHeaders(Astro.response, 86400, 3600);
}

// The live recompute (localhost only) runs ~8s server-side, so the dev client
// needs a deadline beyond the usual 8s abort; prod keeps the tight default.
const supabase = supabaseFor(Astro, isDev ? { timeoutMs: 25000 } : undefined);

let stats: any = null;
{
  // Server-side the numbers come precomputed: the RPC reads a one-row cache that
  // pg_cron refreshes nightly, so this is a single fast round trip. On localhost
  // p_fresh forces a live recompute instead (throttled server-side to 10s).
  const { data, error } = await supabase.rpc('get_archive_stats', isDev ? { p_fresh: true } : {});
  if (error) {
    console.error('archive stats failed:', error.message);
    setDegraded(Astro.response);
  } else {
    stats = data;
  }
}

// "9.5 TB" — sizes on this page get big enough that format.ts's GB ceiling
// reads awkwardly.
function formatBigSize(bytes: unknown): string {
  const b = Number(bytes);
  if (!Number.isFinite(b) || b <= 0) return '';
  const tib = 1024 * 1024 * 1024 * 1024;
  if (b >= tib) return `${(b / tib).toFixed(1)} TB`;
  return formatFileSize(b);
}

const bar = (label: string, value: number, extra: Partial<BarDatum> = {}): BarDatum => ({
  label,
  value: Number(value) || 0,
  display: formatNumber(value),
  ...extra,
});

// The "as of" line shows the exact timestamp the numbers were computed — down to
// the minute (UTC), so on localhost a live recompute is visibly fresh.
const asOfFmt = new Intl.DateTimeFormat('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
  hour: 'numeric', minute: '2-digit', timeZone: 'UTC', timeZoneName: 'short',
});

let asOf = '';
let tiles: { n: string; label: string }[] = [];
let charts: Record<string, string> = {};
let records: { title: string; entries: { text: string; detail: string; href?: string; icon?: string }[] }[] = [];
let notes: string[] = [];

if (stats) {
  const computedAt = stats.computed_at ? new Date(stats.computed_at) : null;
  asOf = computedAt && !isNaN(computedAt.getTime()) ? asOfFmt.format(computedAt) : formatDate(stats.computed_at);

  tiles = [
    { n: formatNumber(stats.apps), label: 'apps' },
    { n: formatNumber(stats.versions), label: 'versions' },
    { n: formatNumber(stats.binaries), label: 'distinct binaries' },
    { n: formatNumber(stats.copies), label: 'archived copies' },
    { n: formatBigSize(stats.total_bytes), label: 'of apps indexed' },
    { n: formatNumber(stats.developers), label: 'developers' },
    { n: formatNumber(stats.distinct_icons), label: 'unique icons' },
    { n: formatNumber(stats.wayback_captures), label: 'archived pages read' },
    { n: formatNumber(stats.listing_snapshots), label: 'store-page snapshots' },
    { n: formatNumber(stats.reviews), label: 'period reviews' },
    { n: formatNumber(stats.chart_positions), label: 'chart placements' },
    { n: formatNumber(stats.chart_snapshots), label: 'weekly chart captures' },
  ];

  const install = stats.install || {};
  charts.install = barChartSVG(
    [
      bar('Installable', install.installable),
      bar('FairPlay-encrypted', install.encrypted, { warn: true }),
      bar('Encryption undetermined', install.unknown),
    ],
    // "Encryption undetermined" needs ~168 viewBox units at 14px — 142 clipped it.
    { title: 'Binaries by install status', labelWidth: 178 }
  );

  const byYear = stats.by_year || {};
  charts.year = barChartSVG(
    Object.keys(byYear)
      .map(Number)
      .sort((a, b) => a - b)
      .map((y) => bar(String(y), byYear[y])),
    { title: 'Versions released by year', labelWidth: 46 }
  );

  // Fold iPhone OS/iOS 11+ together — the archive's heart is 2–10.
  const minOs = stats.min_os || {};
  const osRows: BarDatum[] = [];
  let osLater = 0;
  for (const key of Object.keys(minOs)) {
    const major = parseInt(key, 10);
    const n = Number(minOs[key]) || 0;
    if (!Number.isFinite(major) || major < 2) continue; // "1"/junk keys
    if (major <= 10) osRows.push(bar(osShortLabel(major), n));
    else osLater += n;
  }
  osRows.sort((a, b) => parseInt(a.label.replace(/\D/g, ''), 10) - parseInt(b.label.replace(/\D/g, ''), 10));
  if (osLater > 0) osRows.push(bar('iOS 11+', osLater));
  charts.os = barChartSVG(osRows, { title: 'Versions by minimum OS', labelWidth: 108 });

  const archs = stats.archs || {};
  charts.arch = barChartSVG(
    ['armv6', 'armv7', 'armv7s', 'arm64'].filter((a) => archs[a]).map((a) => bar(a, archs[a])),
    { title: 'Binaries by CPU architecture', labelWidth: 72, mono: true }
  );

  const fam = stats.device_family || {};
  charts.device = barChartSVG(
    [
      bar('Universal', fam.universal),
      bar('iPhone / iPod touch', fam.iphone_only),
      bar('iPad only', fam.ipad_only),
    ],
    { title: 'Versions by device family', labelWidth: 152 }
  );

  const genreRows = (stats.top_genres || []).map((g: any) =>
    bar(String(g.g), g.n, { href: g.gid ? `/categories/${g.gid}` : undefined })
  );
  charts.genre = barChartSVG(genreRows, { title: 'Apps by category', labelWidth: 134 });
  // Games dwarfs every other category, so a Games-free view re-balances the bars
  // (barChartSVG rescales to its own rows' max). Toggled client-side.
  charts.genreNoGames = barChartSVG(
    genreRows.filter((r) => r.label !== 'Games'),
    { title: 'Apps by category (excluding Games)', labelWidth: 134 }
  );

  const revStars = stats.review_stars || {};
  charts.stars = barChartSVG(
    [5, 4, 3, 2, 1].map((s) => bar(`${s} star${s === 1 ? '' : 's'}`, revStars[s])),
    { title: 'Reviews by star rating', labelWidth: 62 }
  );

  // Each record group differs only in which rows it reads and how the detail
  // column is formatted; the name/link/icon shape is identical.
  const recordEntries = (rows: any[], detailOf: (a: any) => string) =>
    (rows || []).map((a: any) => ({
      text: String(a.name),
      detail: detailOf(a),
      href: a.id ? `/app/${a.id}` : undefined,
      icon: appIconSrc(a.icon_sha, a.icon),
    }));

  records = [
    { title: 'Most versions preserved', entries: recordEntries(stats.most_versions, (a) => `${formatNumber(a.n)} versions`) },
    { title: 'Biggest downloads', entries: recordEntries(stats.biggest, (a) => formatFileSize(a.bytes)) },
    { title: 'Steepest price tags', entries: recordEntries(stats.priciest, (a) => String(a.price)) },
  ];

  const pct = (a: number, b: number) => (b > 0 ? Math.round((a / b) * 100) : 0);
  notes = [
    `Release dates are known or calibrated for ${formatNumber(stats.versions_dated)} of ${formatNumber(stats.versions)} versions; the "releases by year" chart counts only those.`,
    `Store availability has been checked for ${formatNumber(stats.apps_checked)} apps so far — ${formatNumber(stats.apps_delisted)} of them (${pct(Number(stats.apps_delisted), Number(stats.apps_checked))}%) are no longer on the App Store.`,
    `${formatNumber(stats.armv6_only_installable)} installable binaries are armv6-only — they run on nothing newer than an iPhone 4 or the first generation iPad, and Legacy Store is likely the only storefront that still serves them.`,
    `Prices are recorded for ${formatNumber(stats.prices?.known)} versions (${formatNumber(stats.prices?.paid)} paid, ${formatNumber(stats.prices?.free)} free at the time). Categories are known for ${formatNumber(stats.apps_with_genre)} apps.`,
    `The oldest datable version was released ${formatDate(stats.oldest_version)} — before the App Store itself opened on July 10, 2008. Chart captures span ${stats.chart_years?.min}–${stats.chart_years?.max}.`,
  ];
}
---

<Layout
  title="Stats — Legacy Store"
  activeTab="none"
  description="The Legacy Store archive by the numbers: apps, versions, binaries, and fifteen years of App Store history."
>
  {!stats ? (
    <div class="db-error">
      <p>The stats are having a moment. Please try again shortly.</p>
    </div>
  ) : (
    <div class="content stats">
      <h1 class="stats-title">Stats</h1>
      <p class="stats-lede">The archive, by the numbers. As of {asOf}.</p>

      <div class="tiles">
        {tiles.map((t) => (
          <div class="tile">
            <span class="tile-n">{t.n}</span>
            <span class="tile-label">{t.label}</span>
          </div>
        ))}
      </div>

      <h2 class="stats-h2">Will it actually run?</h2>
      <p class="stats-sub">Every distinct binary is labelled up front, so nobody wastes a download on an app that installs but never launches.</p>
      <Fragment set:html={charts.install} />

      <h2 class="stats-h2">Releases by year</h2>
      <p class="stats-sub">When the archive's versions shipped. The early gold rush is very visible.</p>
      <Fragment set:html={charts.year} />

      <h2 class="stats-h2">Minimum OS version</h2>
      <p class="stats-sub">What each version declares it needs — the whole point is how much of the archive still suits a first-generation device.</p>
      <Fragment set:html={charts.os} />

      <h2 class="stats-h2">CPU architectures</h2>
      <p class="stats-sub">Read from each binary's Mach-O header; fat binaries count once per slice.</p>
      <Fragment set:html={charts.arch} />

      <h2 class="stats-h2">Devices</h2>
      <p class="stats-sub">Versions with a known device family.</p>
      <Fragment set:html={charts.device} />

      <h2 class="stats-h2">Categories</h2>
      <div class="cat-head">
        <p class="stats-sub cat-sub">The ten biggest, of the apps whose category is known.</p>
        <button type="button" class="cat-toggle" id="cat-toggle" hidden>Hide Games</button>
      </div>
      <div class="cat-chart" data-cat="all"><Fragment set:html={charts.genre} /></div>
      <div class="cat-chart" data-cat="nogames" hidden><Fragment set:html={charts.genreNoGames} /></div>

      <h2 class="stats-h2">Record holders</h2>
      <div class="records">
        {records.map((group) => (
          <div class="record-group">
            <span class="record-title">{group.title}</span>
            <ul class="record-list">
              {group.entries.map((e) => (
                <li>
                  <span class="record-icon">
                    {e.icon ? <><img src={e.icon} alt="" width="29" height="29" loading="lazy" decoding="async" /><span class="icon-mask"></span></> : null}
                  </span>
                  {e.href ? <a class="record-link" href={e.href}>{e.text}</a> : <span class="record-link">{e.text}</span>}
                  <span class="record-detail">{e.detail}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <h2 class="stats-h2">What people said at the time</h2>
      <p class="stats-sub">{formatNumber(stats.reviews)} customer reviews recovered from archived review feeds, stars and all.</p>
      <Fragment set:html={charts.stars} />

      <h2 class="stats-h2">The fine print</h2>
      <ul class="notes">
        {notes.map((n) => (
          <li>{n}</li>
        ))}
      </ul>
    </div>
  )}

  <style>
    .stats {
      max-width: 640px;
      padding-bottom: 32px;
    }

    .stats-title {
      margin: 14px 0 2px 0;
      font-size: 26px;
      line-height: 30px;
      color: #474747;
    }

    .stats-lede {
      margin: 0 0 14px 0;
      color: #898989;
      font-size: 15px;
      font-style: italic;
    }

    .stats-h2 {
      margin: 26px 0 4px 0;
      font-size: 18px;
      line-height: 22px;
      color: #474747;
      border-top: 1px solid #ececec;
      padding-top: 18px;
    }

    .stats-sub {
      margin: 0 0 10px 0;
      color: #898989;
      font-size: 13px;
      line-height: 17px;
    }

    .chart-box {
      margin: 0 0 8px 0;
    }

    /* Headline tiles — inline-block so they reflow on any width and any-era Safari */
    .tiles {
      margin: 0 -4px;
    }

    .tile {
      display: inline-block;
      vertical-align: top;
      width: 31%;
      margin: 4px 1%;
      padding: 12px 0 10px 0;
      text-align: center;
      background: #F3F9FD;
      border-radius: 4px;
      -webkit-box-sizing: border-box;
      box-sizing: border-box;
    }

    .tile-n {
      display: block;
      font-size: 20px;
      line-height: 24px;
      font-weight: bold;
      color: #298cda;
    }

    .tile-label {
      display: block;
      color: #898989;
      font-size: 11px;
      line-height: 15px;
    }

    @media screen and (max-width: 480px) {
      .tile { width: 48%; }
      .tile-n { font-size: 17px; line-height: 21px; }
    }

    /* Record holders */
    .records {
      margin: 4px 0 0 0;
    }

    .record-group {
      margin: 0 0 14px 0;
    }

    .record-title {
      display: block;
      font-size: 13px;
      font-weight: bold;
      color: #474747;
      margin-bottom: 2px;
    }

    .record-list {
      list-style: none;
      margin: 0;
      padding: 0;
      background: #F3F9FD;
      border-radius: 4px;
      overflow: hidden;
    }

    .record-list li {
      padding: 7px 12px;
      border-bottom: 1px solid #e3edf5;
      font-size: 12px;
      line-height: 29px;
      overflow: hidden;
    }

    .record-list li:last-child { border-bottom: none; }

    .record-icon {
      position: relative;
      float: left;
      width: 29px;
      height: 29px;
      margin: 0 9px 0 0;
      border-radius: 6px;
      background: transparent url('/icon-placeholder.png') no-repeat;
      background-size: 100% 100%;
    }

    .record-icon .icon-mask {
      left: 0;
      width: 100%;
      height: 100%;
      background-image: url('/wsf/images/mask100blue.png');
      background-size: 100% 100%;
    }

    .record-icon img {
      display: block;
      width: 29px;
      height: 29px;
    }

    .record-link {
      color: #298cda;
      font-weight: bold;
    }

    .record-detail {
      float: right;
      color: #898989;
    }

    /* Categories: "Hide Games" toggle, revealed only when JS runs. */
    .cat-head {
      position: relative;
    }

    .cat-sub {
      margin-right: 92px;
    }

    .cat-toggle {
      position: absolute;
      top: -2px;
      right: 0;
      -webkit-appearance: none;
      appearance: none;
      font-size: 12px;
      line-height: 1;
      color: #298cda;
      font-weight: bold;
      background: #fff;
      border: 1px solid #c8c8cc;
      border-radius: 10px;
      padding: 6px 10px;
      cursor: pointer;
    }

    .cat-toggle:active { background: #e8e8ea; }

    /* Explicit so old WebKit (no native [hidden] UA rule) still hides these. */
    .cat-chart[hidden],
    .cat-toggle[hidden] { display: none; }

    .notes {
      margin: 0;
      padding-left: 20px;
    }

    .notes li {
      margin: 0 0 8px 0;
      font-size: 13px;
      line-height: 18px;
      color: #767676;
    }
  </style>

  <!-- "Hide Games" toggle. Deliberately old-WebKit-safe (iOS 4/5/6): no
       const/let, no arrow functions, no template strings, no classList. If
       unsupported the script no-ops, the button stays hidden, and the
       server-rendered (games-included) chart keeps showing. -->
  <script is:inline>
    (function () {
      if (!document.getElementById || !document.querySelector) return;
      var toggle = document.getElementById('cat-toggle');
      var all = document.querySelector('.cat-chart[data-cat="all"]');
      var nogames = document.querySelector('.cat-chart[data-cat="nogames"]');
      if (!toggle || !all || !nogames) return;

      function setHidden(el, h) {
        if (h) el.setAttribute('hidden', 'hidden');
        else el.removeAttribute('hidden');
      }

      setHidden(toggle, false);
      var gamesHidden = false;
      toggle.onclick = function () {
        gamesHidden = !gamesHidden;
        setHidden(all, gamesHidden);
        setHidden(nogames, !gamesHidden);
        toggle.innerHTML = gamesHidden ? 'Show Games' : 'Hide Games';
        return false;
      };
    })();
  </script>
</Layout>
