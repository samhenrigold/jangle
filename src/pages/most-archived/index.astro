---
import { supabaseFor } from '../../lib/supabase';
import Layout from '../../components/Layout.astro';
import DbError from '../../components/DbError.astro';
import Pagination from '../../components/Pagination.astro';
import AppList from '../../components/AppList.astro';
import { cacheGet, cacheSet } from '../../lib/cache';
import { clampPage, clampPageSize } from '../../lib/search';
import { setCacheHeaders, setDegraded } from '../../lib/http';
import { getPeakLines } from '../../lib/timemachine';
import { getOldestIcons } from '../../lib/appicons';

setCacheHeaders(Astro.response, 3600);

const url = new URL(Astro.request.url);
const page = clampPage(url.searchParams.get('page'));
// 25 per page — the tab is literally called Top 25.
const pageSize = clampPageSize(url.searchParams.get('per_page'), 25);
const offset = (page - 1) * pageSize;

const supabase = supabaseFor(Astro);
let dbError = false;

// Fetch top charts apps (sorted by most versions)
const topChartsCacheKey = `topcharts:${page}:${pageSize}`;
let topChartsApps = cacheGet<any[]>(topChartsCacheKey);
if (!topChartsApps) {
  const { data, error } = await supabase.rpc('get_apps_sorted_by_version_count', {
    p_limit: pageSize,
    p_offset: offset,
    p_genre_id: null,
    p_ascending: false,
    p_search_query: null,
  });
  topChartsApps = data || [];
  if (error) {
    console.error('charts list failed:', error.message);
    dbError = true;
  } else {
    cacheSet(topChartsCacheKey, topChartsApps, 5 * 60 * 1000);
  }
}

// Get total count for pagination
const countCacheKey = 'topcharts_count';
let total = cacheGet<number>(countCacheKey);
if (!dbError && typeof total !== 'number') {
  const { data: totalCountArr, error } = await supabase.rpc('get_apps_count', { p_genre_id: null, p_search_query: null });
  total = Array.isArray(totalCountArr) ? totalCountArr[0] : totalCountArr;
  if (error) {
    console.error('charts count failed:', error.message);
    dbError = true;
  } else {
    cacheSet(countCacheKey, Number(total) || 0, 10 * 60 * 1000);
  }
}

const totalPages = Math.max(1, Math.ceil((Number(total) || 0) / pageSize));

// Historical peak badges + period-authentic icons — both decorative, so a
// failure here just drops the badges/icons rather than 503-ing the list.
let peakLines: Map<number, string> | undefined;
let iconShas: Map<number, string> | undefined;
if (!dbError && (topChartsApps || []).length) {
  const ids = (topChartsApps || []).map((a: any) => Number(a.app_store_id)).filter(Boolean);
  peakLines = (await getPeakLines(supabase, ids, `top25:${page}:${pageSize}`)) || undefined;
  iconShas = await getOldestIcons(supabase, (topChartsApps || []).map((a: any) => Number(a.id)));
}

// A transient DB failure must not render as a cacheable empty page.
if (dbError) setDegraded(Astro.response);
---

<Layout title="Top 25 Most Archived — Legacy Store" activeTab="none" description="The most-archived apps on Legacy Store — classic iPhone and iPad apps ranked by how many versions the archive holds.">
  <div class="content">
    {dbError ? (
      <DbError />
    ) : (
      <>
        <div class="section-header">
          <h1 class="section-title">Top 25 Most Archived</h1>
          <span class="section-detail">Ranked by how many versions the archive holds — not by popularity.</span>
        </div>
        <AppList list={topChartsApps} startRank={offset + 1} peakLines={peakLines} iconShas={iconShas} />

        {totalPages > 1 && <Pagination page={page} totalPages={totalPages} hrefFor={(p) => `/most-archived?page=${p}${pageSize !== 25 ? `&per_page=${pageSize}` : ''}`} nextLabel={`Next ${pageSize}`} />}
      </>
    )}
  </div>
</Layout>
