---
import { getSupabaseClient } from '../lib/supabase';
import Layout from '../components/Layout.astro';
import SearchForm from '../components/SearchForm.astro';
import AppList from '../components/AppList.astro';
import { cacheGet, cacheSet } from '../lib/cache';

// SSR search parameters
const url = new URL(Astro.request.url);
const q = url.searchParams.get('q') || '';
const genreId = url.searchParams.get('genre');
const sort = url.searchParams.get('sort') || 'versions'; // versions | first_date | name
const page = Number(url.searchParams.get('page') || '1');
const pageSize = Math.min(50, Number(url.searchParams.get('per_page') || '20'));
const offset = (page - 1) * pageSize;

const supabase = getSupabaseClient();

// Fetch genres for filter sidebar
const genresCacheKey = 'genres_with_counts';
let genres = cacheGet<any[]>(genresCacheKey);
if (!genres) {
  const { data } = await supabase.rpc('get_genres_with_counts');
  genres = data || [];
  cacheSet(genresCacheKey, genres, 10 * 60 * 1000);
}

// Fetch total count and list using server functions
const countArgs: Record<string, any> = {
  p_genre_id: genreId ? Number(genreId) : null,
  p_search_query: q ? q.split(/\s+/).map((t) => `${t}:*`).join(' & ') : null,
};
const countCacheKey = `count:${genreId||''}:${q}`;
let total = cacheGet<number>(countCacheKey);
if (typeof total !== 'number') {
  const { data: totalCountArr } = await supabase.rpc('get_apps_count', countArgs);
  total = Array.isArray(totalCountArr) ? totalCountArr[0] : totalCountArr;
  cacheSet(countCacheKey, Number(total) || 0, 2 * 60 * 1000);
}

const rpcArgs = {
  p_limit: pageSize,
  p_offset: offset,
  p_genre_id: countArgs.p_genre_id,
  p_ascending: false,
  p_search_query: countArgs.p_search_query,
};

const listCacheKey = `list:${sort}:${genreId||''}:${q}:${page}:${pageSize}`;
let list = cacheGet<any[]>(listCacheKey);
if (!list) {
  if (sort === 'first_date') {
    const { data } = await supabase.rpc('get_apps_sorted_by_first_version_date', rpcArgs);
    list = data || [];
  } else if (sort === 'name') {
    const { data } = await supabase
      .from('apps')
      .select('*, developers!apps_developer_id_fkey(artist_name)')
      .order('display_name', { ascending: true })
      .range(offset, offset + pageSize - 1);
    list = (data || []).map((a: any) => ({
      ...a,
      developer_artist_name: (a as any).developers?.artist_name,
      version_count: undefined,
    }));
  } else {
    const { data } = await supabase.rpc('get_apps_sorted_by_version_count', rpcArgs);
    list = data || [];
  }
  cacheSet(listCacheKey, list, 60 * 1000);
}

const totalPages = Math.max(1, Math.ceil((Number(total) || 0) / pageSize));
---

<Layout title="Jangle — Legacy App Archive">
  <div style="display:grid;grid-template-columns:220px 1fr;gap:16px;">
    <aside>
      <SearchForm q={q} genreId={genreId} sort={sort} genres={genres} />
      <div class="meta" style="margin-top:10px;color:#666;font-size:13px;">Total results: {Number(total) || 0}</div>
    </aside>
    <section>
      <AppList list={list} />
      <nav class="pagination" style="display:flex;gap:8px;margin-top:12px;">
        {page > 1 && (
          <a href={`/?q=${encodeURIComponent(q)}&genre=${genreId||''}&sort=${sort}&page=${page-1}&per_page=${pageSize}`}>Prev</a>
        )}
        <span>Page {page} / {totalPages}</span>
        {page < totalPages && (
          <a href={`/?q=${encodeURIComponent(q)}&genre=${genreId||''}&sort=${sort}&page=${page+1}&per_page=${pageSize}`}>Next</a>
        )}
      </nav>
    </section>
  </div>
</Layout>
