---
import { supabaseFor } from '../lib/supabase';
import Layout from '../components/Layout.astro';
import DbError from '../components/DbError.astro';
import AppList from '../components/AppList.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { cacheGet, cacheSet } from '../lib/cache';
import { setCacheHeaders, setDegraded } from '../lib/http';
import { iconSrc, appIconSrc } from '../lib/icons';
import { formatDate } from '../lib/format';
import {
  getChartTypes,
  getSnapshotIndex,
  getSnapshotPositions,
  getPeakLines,
  dedupeByDate,
  nearestSnapshot,
  deviceOf,
  formatPrice,
} from '../lib/timemachine';
import { getIconsNearDate } from '../lib/appicons';

setCacheHeaders(Astro.response, 3600);

const supabase = supabaseFor(Astro);
let dbError = false;

let featuredApps: any[] | undefined;
let iconShas: Map<number, string> | undefined;
let peakLines: Map<number, string> | undefined;
let heroSnapshot: any = null;
let heroType: any = null;
let heroEntries: any[] = [];
let heroIconShas: Map<number, string> | undefined;
let heroYearsAgo = 0;

// Featured: the 'featured' editorial collection (collections table) — the
// hand-picked list that used to live in src/lib/featured.ts. The only chain
// allowed to set dbError; peak badges chain onto it since they need the ids.
const loadFeatured = async () => {
  const featuredCacheKey = 'featured_apps_v3';
  featuredApps = cacheGet<any[]>(featuredCacheKey);
  if (!featuredApps) {
    const { data, error } = await supabase
      .from('collections')
      .select('collection_members(position, apps!collection_members_app_id_fkey(id, app_store_id, bundle_id, app_store_name, display_name, version_count, oldest_icon_sha256, excluded, icon_url:live_icon_url, developers!apps_developer_id_fkey(artist_name)))')
      .eq('slug', 'featured')
      .maybeSingle();
    if (error) {
      console.error('featured query failed:', error.message);
      featuredApps = [];
      dbError = true;
      return;
    }
    // An unpublished/missing 'featured' collection is an empty section, not
    // an outage.
    featuredApps = (data?.collection_members || [])
      .sort((x: any, y: any) => x.position - y.position)
      .map((m: any) => m.apps)
      .filter((a: any) => a && !a.excluded)
      .map((a: any) => ({ ...a, developer_artist_name: a.developers?.artist_name }));
    cacheSet(featuredCacheKey, featuredApps, 10 * 60 * 1000);
  }
  // Period-authentic (oldest) icons ride the embed — no second query.
  iconShas = new Map(
    featuredApps
      .filter((a: any) => a.oldest_icon_sha256)
      .map((a: any) => [Number(a.id), a.oldest_icon_sha256] as [number, string])
  );
  // Peak-chart badges — best-effort decoration on top of the list.
  const ids = featuredApps.map((a: any) => Number(a.app_store_id)).filter((n: number) => n > 0);
  if (ids.length) peakLines = (await getPeakLines(supabase, ids, 'featured')) || undefined;
};

// "This week, years ago" module (plan 010 charts): deterministic per calendar
// week so the page stays edge-cacheable — the week number picks Top Free vs
// Top Paid, and the capture nearest to this month/day 15 years back is shown.
// Decorative: a failure leaves the Featured list standing, never 503s.
const loadHero = async () => {
  const [chartTypes, snapshotIndex] = await Promise.all([
    getChartTypes(supabase),
    getSnapshotIndex(supabase),
  ]);
  if (!chartTypes || !snapshotIndex || !snapshotIndex.length) return;
  const now = new Date();
  const week = Math.floor((now.getTime() - Date.UTC(now.getUTCFullYear(), 0, 1)) / (7 * 86400000));
  const slug = week % 2 ? 'top-paid' : 'top-free';
  heroType = chartTypes.find((t: any) => t.slug === slug) || chartTypes[0];
  heroYearsAgo = 15;
  const target = `${now.getUTCFullYear() - heroYearsAgo}-${String(now.getUTCMonth() + 1).padStart(2, '0')}-${String(now.getUTCDate()).padStart(2, '0')}`;
  const candidates = dedupeByDate(
    snapshotIndex.filter(
      (s) => s.chart_type_id === Number(heroType?.id) && s.genre_id === null && deviceOf(s.source_url) === 'iphone'
    )
  );
  heroSnapshot = nearestSnapshot(candidates, target);
  if (heroSnapshot) {
    const positions = await getSnapshotPositions(supabase, heroSnapshot.id);
    // null = enrichment query failed; drop the hero, keep the page.
    if (positions) {
      heroEntries = positions.slice(0, 5);
      // Icons dated nearest the snapshot, not each app's oldest (decorative —
      // an empty map just leaves the oldest-icon fallback in place).
      const ids = heroEntries.map((p: any) => Number(p.apps?.id)).filter(Boolean);
      if (ids.length) heroIconShas = await getIconsNearDate(supabase, ids, heroSnapshot.snapshot_date);
    } else heroSnapshot = null;
  }
};

// Featured collections teaser: editorial collections flagged for the landing
// page (featured_rank). Decorative — a failure drops the module, never 503s.
type HomeCollection = { slug: string; title: string; subtitle: string | null; icons: string[] };
let homeCollections: HomeCollection[] = [];
const loadCollections = async () => {
  const key = 'home_collections_v1';
  const cached = cacheGet<HomeCollection[]>(key);
  if (cached) {
    homeCollections = cached;
    return;
  }
  const { data, error } = await supabase
    .from('collections')
    .select('slug, title, subtitle, featured_rank, collection_members(position, apps!collection_members_app_id_fkey(oldest_icon_sha256, icon_url:live_icon_url, excluded))')
    .not('featured_rank', 'is', null)
    .order('featured_rank', { ascending: true })
    .limit(3);
  if (error || !data) return;
  homeCollections = data.map((c: any) => ({
    slug: c.slug,
    title: c.title,
    subtitle: c.subtitle,
    icons: (c.collection_members || [])
      .filter((m: any) => m.apps && !m.apps.excluded)
      .sort((x: any, y: any) => x.position - y.position)
      .map((m: any) => appIconSrc(m.apps.oldest_icon_sha256, m.apps.icon_url))
      .filter(Boolean)
      .slice(0, 4),
  }));
  cacheSet(key, homeCollections, 10 * 60 * 1000);
};

await Promise.all([loadFeatured(), loadHero(), loadCollections()]);

const heroDateLabel = heroSnapshot ? formatDate(heroSnapshot.snapshot_date) : '';
const heroHref = heroSnapshot && heroType
  ? `/charts?${heroType.slug !== 'top-free' ? `type=${heroType.slug}&` : ''}date=${heroSnapshot.snapshot_date}`
  : '/charts';

// A transient DB failure must not render as a cacheable empty page.
if (dbError) setDegraded(Astro.response);
---

<Layout title="Legacy Store" activeTab="featured" description="Browse and install archived versions of classic iPhone and iPad apps, directly on your old iOS device.">
  <div class="content">
    {dbError ? (
      <DbError />
    ) : (
      <>
        {homeCollections.length > 0 && (
          <>
            <SectionHeader title="Collections">
              <a href="/collections">See all</a>
            </SectionHeader>
            {/* A row of cards; narrow screens swipe it sideways. inline-block +
                overflow-x is the old-WebKit-safe way to get a card carousel. */}
            <div class="colx-scroll">
              {homeCollections.map((c) => (
                <a class="colx-card" href={`/collections/${c.slug}`}>
                  <span class="colx-icons">
                    {c.icons.map((src) => (
                      <span class="colx-icon"><img src={src} alt="" width="40" height="40" loading="lazy" /><span class="icon-mask"></span></span>
                    ))}
                  </span>
                  <span class="colx-title">{c.title}</span>
                  {c.subtitle && <span class="colx-sub">{c.subtitle}</span>}
                </a>
              ))}
            </div>
          </>
        )}

        {heroSnapshot && heroEntries.length > 0 && (
          <>
            <SectionHeader title={`${heroYearsAgo} Years Ago This Week`} />
            <div class="hero-card">
              <div class="hero-head">
                <span class="hero-chart">{heroType.name}</span> as of {heroDateLabel}
              </div>
              <ul class="hero-list">
                {heroEntries.map((p: any) => {
                  // Chart-date artwork first (period-correct, /img-resurrected),
                  // then the archive's own icon nearest the snapshot date, then
                  // its oldest extracted icon; the app's LIVE listing icon
                  // (modern, era-wrong) only as a last resort.
                  const icon = iconSrc(p.artwork_url)
                    || appIconSrc(
                      heroIconShas?.get(Number(p.apps?.id)) || p.apps?.oldest_icon_sha256,
                      p.apps?.icon_url);
                  const price = formatPrice(p.price_amount, p.price_currency);
                  const href = p.apps ? `/app/${p.apps.app_store_id || p.apps.id}` : null;
                  const inner = (
                    <>
                      <span class="hero-rank">{p.position}</span>
                      <span class="hero-icon">{icon ? <><img src={icon} alt="" width="29" height="29" loading="lazy" /><span class="icon-mask"></span></> : null}</span>
                      <span class="hero-price">{price}</span>
                      <span class="hero-name">{p.display_name}</span>
                    </>
                  );
                  return (
                    <li class="hero-row" data-app-store-id={p.app_store_id || undefined} data-bundle-id={p.apps?.bundle_id || undefined}>
                      {href
                        ? <a class="hero-row-link" href={href}>{inner}</a>
                        : <span class="hero-row-link hero-row-dead">{inner}</span>}
                    </li>
                  );
                })}
              </ul>
              <a class="hero-cta" href={heroHref}>See the full chart</a>
            </div>
          </>
        )}

        <SectionHeader title="Featured" detail="greatest hits from the archive" />
        <AppList list={featuredApps} peakLines={peakLines} iconShas={iconShas} />
      </>
    )}
  </div>

  <style>
    /* Featured collections — a card row that swipes sideways when narrow */
    .colx-scroll {
      margin: 0 0 6px 0;
      white-space: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
    }

    .colx-card {
      display: inline-block;
      vertical-align: top;
      width: 31.5%;
      min-width: 210px;
      margin-right: 1.9%;
      padding: 12px 14px;
      background: #F3F9FD;
      border-radius: 4px;
      white-space: normal;
      -webkit-box-sizing: border-box;
      box-sizing: border-box;
    }

    .colx-card:last-child {
      margin-right: 0;
    }

    a.colx-card:hover {
      text-decoration: none;
      background-color: #eaf3f8;
    }

    .colx-icons {
      display: block;
      height: 40px;
      margin-bottom: 8px;
      overflow: hidden;
    }

    .colx-icon {
      position: relative;
      float: left;
      width: 40px;
      height: 40px;
      margin-right: 6px;
      background: transparent url('/icon-placeholder.png') no-repeat;
      background-size: 100% 100%;
    }

    .colx-icon img {
      display: block;
      width: 40px;
      height: 40px;
    }

    /* Blue-panel surface: use Apple's blue-cornered gloss mask */
    .colx-icon .icon-mask {
      left: 0;
      width: 100%;
      height: 100%;
      background-image: url('/wsf/images/mask100blue.png');
      background-size: 100% 100%;
    }

    .colx-title {
      display: block;
      font-size: 13px;
      font-weight: bold;
      line-height: 17px;
      color: #298cda;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .colx-sub {
      display: block;
      color: #898989;
      font-size: 11px;
      line-height: 15px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* "This week, years ago" hero — a blue swoosh panel in the era idiom */
    .hero-card {
      background: #F3F9FD;
      border-radius: 4px;
      padding: 0 16px 8px 16px;
      overflow: hidden;
    }

    .hero-head {
      padding: 12px 0 6px 0;
      color: #898989;
      font-size: 11px;
      line-height: 16px;
      border-bottom: 1px solid #e3edf5;
    }

    .hero-chart {
      font-weight: bold;
      color: #474747;
      font-size: 13px;
    }

    .hero-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .hero-row {
      border-bottom: 1px solid #e3edf5;
    }

    .hero-row-link {
      display: block;
      padding: 6px 2px;
      overflow: hidden;
    }

    a.hero-row-link:hover {
      text-decoration: none;
      background-color: #eaf3f8;
    }

    .hero-rank {
      float: left;
      width: 20px;
      margin-right: 8px;
      line-height: 29px;
      text-align: right;
      font-size: 11px;
      font-weight: bold;
      color: #898989;
    }

    .hero-icon {
      position: relative;
      float: left;
      width: 29px;
      height: 29px;
      margin-right: 8px;
      background: transparent url('/icon-placeholder.png') no-repeat;
      background-size: 100% 100%;
    }

    .hero-icon img {
      display: block;
      width: 29px;
      height: 29px;
    }

    /* Blue-panel surface: use Apple's blue-cornered gloss mask */
    .hero-icon .icon-mask {
      left: 0;
      width: 100%;
      height: 100%;
      background-image: url('/wsf/images/mask100blue.png');
      background-size: 100% 100%;
    }

    .hero-price {
      float: right;
      margin-left: 8px;
      line-height: 29px;
      color: #898989;
      font-size: 11px;
      font-weight: bold;
    }

    .hero-name {
      display: block;
      overflow: hidden;
      line-height: 29px;
      font-size: 12px;
      font-weight: bold;
      color: #298cda;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* A chart entry we couldn't match to an archived app isn't a link — don't
       paint its title link-blue, or it reads as clickable. */
    .hero-row-dead .hero-name {
      color: #898989;
    }

    .hero-cta {
      display: block;
      padding: 8px 2px;
      border-top: 1px solid #e3edf5;
      color: #298cda;
      font-size: 12px;
      font-weight: bold;
    }

    .hero-cta:after {
      content: "";
      display: inline-block;
      width: 4px;
      height: 7px;
      margin-left: 6px;
      background: url('/wsf/images/more.gif') 0 0 no-repeat;
    }
  </style>
</Layout>
