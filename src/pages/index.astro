---
import { getSupabaseClient } from '../lib/supabase';
import Layout from '../components/Layout.astro';
import AppList from '../components/AppList.astro';
import { cacheGet, cacheSet } from '../lib/cache';
import { setCacheHeaders } from '../lib/http';

setCacheHeaders(Astro.response, 3600);

const supabase = getSupabaseClient((Astro.locals as any)?.runtime?.env);

// Featured: First 5 apps
const featuredCacheKey = 'featured_apps';
let featuredApps = cacheGet<any[]>(featuredCacheKey);
if (!featuredApps) {
  const { data } = await supabase
    .from('apps')
    .select('id, app_store_id, bundle_id, app_store_name, developer_id, genre_id, icon_url, display_name, executable_name, developers!apps_developer_id_fkey(artist_name)')
    .limit(5);
  featuredApps = (data || []).map((a: any) => ({
    ...a,
    developer_artist_name: (a as any).developers?.artist_name,
    version_count: undefined,
  }));
  cacheSet(featuredCacheKey, featuredApps, 10 * 60 * 1000);
}
---

<Layout title="Legacy Store" activeTab="featured">
  <div class="content">
    <AppList list={featuredApps} />
  </div>

  <style>
    .content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }
  </style>
</Layout>
