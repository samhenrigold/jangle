---
import { supabaseFor } from '../lib/supabase';
import Layout from '../components/Layout.astro';
import DbError from '../components/DbError.astro';
import AppList from '../components/AppList.astro';
import { cacheGet, cacheSet } from '../lib/cache';
import { setCacheHeaders, setDegraded } from '../lib/http';
import { FEATURED_APP_STORE_IDS } from '../lib/featured';
import { iconSrc } from '../lib/icons';
import { formatDate } from '../lib/format';
import { getOldestIcons } from '../lib/appicons';
import {
  getChartTypes,
  getSnapshotIndex,
  getSnapshotPositions,
  getPeakLines,
  dedupeByDate,
  nearestSnapshot,
  deviceOf,
  formatPrice,
} from '../lib/timemachine';

setCacheHeaders(Astro.response, 3600);

const supabase = supabaseFor(Astro);
let dbError = false;

// Featured: hand-picked greatest hits (src/lib/featured.ts) until the
// editorial charts layer ships.
const featuredCacheKey = 'featured_apps_v2';
let featuredApps = cacheGet<any[]>(featuredCacheKey);
if (!featuredApps) {
  const { data, error } = await supabase
    .from('apps')
    .select('id, app_store_id, bundle_id, app_store_name, developer_id, genre_id, icon_url, display_name, version_count, developers!apps_developer_id_fkey(artist_name)')
    .in('app_store_id', FEATURED_APP_STORE_IDS);
  if (error) {
    console.error('featured query failed:', error.message);
    featuredApps = [];
    dbError = true;
  } else {
    // Collapse duplicate app_store_id rows to the lowest internal id (matches
    // /app/ routing), then lay out in curated order.
    const byStoreId = new Map<number, any>();
    for (const a of data || []) {
      const cur = byStoreId.get(a.app_store_id);
      if (!cur || a.id < cur.id) byStoreId.set(a.app_store_id, a);
    }
    featuredApps = FEATURED_APP_STORE_IDS
      .map((id) => byStoreId.get(id))
      .filter(Boolean)
      .map((a: any) => ({ ...a, developer_artist_name: a.developers?.artist_name }));
    cacheSet(featuredCacheKey, featuredApps, 10 * 60 * 1000);
  }
}

// --- "This week, years ago" module (plan 010 charts) ------------------------
// Deterministic per calendar week so the page stays edge-cacheable: the week
// number picks Top Free vs Top Paid, and the capture nearest to this
// month/day 15 years back is shown.
// Everything below is decorative enrichment — a slow/failed query here must
// leave the Featured list standing, never 503 the page. Only the core featured
// query (above) is allowed to set dbError.
const [chartTypes, snapshotIndex] = await Promise.all([
  getChartTypes(supabase),
  getSnapshotIndex(supabase),
]);

let heroSnapshot: any = null;
let heroType: any = null;
let heroEntries: any[] = [];
let heroYearsAgo = 0;
if (!dbError && chartTypes && snapshotIndex && snapshotIndex.length) {
  const now = new Date();
  const week = Math.floor((now.getTime() - Date.UTC(now.getUTCFullYear(), 0, 1)) / (7 * 86400000));
  const slug = week % 2 ? 'top-paid' : 'top-free';
  heroType = chartTypes.find((t: any) => t.slug === slug) || chartTypes[0];
  heroYearsAgo = 15;
  const target = `${now.getUTCFullYear() - heroYearsAgo}-${String(now.getUTCMonth() + 1).padStart(2, '0')}-${String(now.getUTCDate()).padStart(2, '0')}`;
  const candidates = dedupeByDate(
    snapshotIndex.filter(
      (s) => s.chart_type_id === Number(heroType?.id) && s.genre_id === null && deviceOf(s.source_url) === 'iphone'
    )
  );
  heroSnapshot = nearestSnapshot(candidates, target);
  if (heroSnapshot) {
    const positions = await getSnapshotPositions(supabase, heroSnapshot.id);
    // null = enrichment query failed; drop the hero, keep the page.
    if (positions) heroEntries = positions.slice(0, 5);
    else heroSnapshot = null;
  }
}

// Peak-chart badges + period-authentic (oldest) icons for the curated list —
// both best-effort (null/empty just means no badges / fallback icons).
let peakLines: Map<number, string> | undefined;
let iconShas: Map<number, string> | undefined;
if (!dbError && featuredApps && featuredApps.length) {
  peakLines = (await getPeakLines(supabase, FEATURED_APP_STORE_IDS, 'featured')) || undefined;
  iconShas = await getOldestIcons(supabase, featuredApps.map((a: any) => Number(a.id)));
}

const heroDateLabel = heroSnapshot ? formatDate(heroSnapshot.snapshot_date) : '';
const heroHref = heroSnapshot && heroType
  ? `/charts?${heroType.slug !== 'top-free' ? `type=${heroType.slug}&` : ''}date=${heroSnapshot.snapshot_date}`
  : '/charts';

// A transient DB failure must not render as a cacheable empty page.
if (dbError) setDegraded(Astro.response);
---

<Layout title="Legacy Store" activeTab="featured" description="Browse and install archived versions of classic iPhone and iPad apps, directly on your old iOS device.">
  <div class="content">
    {dbError ? (
      <DbError />
    ) : (
      <>
        {heroSnapshot && heroEntries.length > 0 && (
          <>
            <div class="section-header">
              <h2 class="section-title">{heroYearsAgo} Years Ago This Week</h2>
            </div>
            <div class="hero-card">
              <div class="hero-head">
                <span class="hero-chart">{heroType.name}</span> as of {heroDateLabel}
              </div>
              <ul class="hero-list">
                {heroEntries.map((p: any) => {
                  const icon = iconSrc(p.artwork_url) || iconSrc(p.apps?.icon_url);
                  const price = formatPrice(p.price_amount, p.price_currency);
                  const href = p.apps ? `/app/${p.apps.app_store_id || p.apps.id}` : null;
                  const inner = (
                    <>
                      <span class="hero-rank">{p.position}</span>
                      <span class="hero-icon">{icon && <img src={icon} alt="" width="29" height="29" loading="lazy" />}<span class="icon-mask"></span></span>
                      <span class="hero-price">{price}</span>
                      <span class="hero-name">{p.display_name}</span>
                    </>
                  );
                  return (
                    <li class="hero-row">
                      {href ? <a class="hero-row-link" href={href}>{inner}</a> : <span class="hero-row-link">{inner}</span>}
                    </li>
                  );
                })}
              </ul>
              <a class="hero-cta" href={heroHref}>See the full chart<span class="hero-cta-chevron">&#8250;</span></a>
            </div>
          </>
        )}

        <div class="section-header">
          <h2 class="section-title">Featured</h2>
          <span class="section-detail">greatest hits from the archive</span>
        </div>
        <AppList list={featuredApps} peakLines={peakLines} iconShas={iconShas} />
      </>
    )}
  </div>

  <style>
    .hero-card {
      border: 1px solid #c8d0dc;
      border-radius: 8px;
      background: #eef1f6;
      overflow: hidden;
    }

    .hero-head {
      padding: 8px 10px;
      color: #4c566c;
      font-size: 12px;
      line-height: 16px;
      border-bottom: 1px solid #d5dbe4;
    }

    .hero-chart {
      font-weight: bold;
    }

    .hero-list {
      list-style: none;
      margin: 0;
      padding: 0;
      background: #fff;
    }

    .hero-row {
      border-bottom: 1px solid #e1e1e1;
    }

    .hero-row-link {
      display: block;
      padding: 6px 10px;
      overflow: hidden;
    }

    a.hero-row-link:active {
      background-color: #e8ebef;
    }

    .hero-rank {
      float: left;
      width: 20px;
      margin-right: 6px;
      line-height: 29px;
      text-align: center;
      font-size: 14px;
      font-weight: bold;
      color: #8e8e93;
    }

    .hero-icon {
      position: relative;
      float: left;
      width: 29px;
      height: 29px;
      margin-right: 8px;
      background: #f3f3f3;
      border-radius: 6px;
      overflow: hidden;
    }

    .hero-icon img {
      display: block;
      width: 29px;
      height: 29px;
    }

    .hero-price {
      float: right;
      margin-left: 8px;
      line-height: 29px;
      color: #385487;
      font-size: 13px;
      font-weight: bold;
    }

    .hero-name {
      display: block;
      overflow: hidden;
      line-height: 29px;
      font-size: 14px;
      font-weight: bold;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .hero-cta {
      display: block;
      padding: 9px 10px;
      background: #f7f7f8;
      border-top: 1px solid #d5dbe4;
      color: #385487;
      font-size: 14px;
      font-weight: bold;
    }

    .hero-cta:active {
      background-color: #e8ebef;
    }

    .hero-cta-chevron {
      float: right;
      color: #c7c7cc;
      font-size: 18px;
      line-height: 18px;
    }
  </style>
</Layout>
