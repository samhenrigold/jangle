# Cloudflare Workers static-assets header rules. Applies ONLY to files served
# straight from /public (static assets) — the dynamic image routes /icon/<sha>,
# /screen/<sha> and /img set their own Cache-Control in the Worker and are not
# affected here.
#
# These files are content-invariant (their bytes never change under the same
# path), so cache them hard and skip the per-request revalidation round-trip.
# icon-placeholder.png alone was the #2 most-requested URL on launch day and was
# revalidating on every hit. If one is ever re-authored, rename it or purge cache.

/icon-placeholder.png
  Cache-Control: public, max-age=31536000, immutable

/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
